@prefix ogit.Compliance:     <http://www.purl.org/ogit/Compliance/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Compliance:listedDate
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "listedDate";
	dcterms:description "Date when a person or organization was first listed on a sanctions list.";
	dcterms:valid "start=2026-04-27;";
	dcterms:creator "chris.boos@almato.com";
.
