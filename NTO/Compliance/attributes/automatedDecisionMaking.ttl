@prefix ogit.Compliance:     <http://www.purl.org/ogit/Compliance/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Compliance:automatedDecisionMaking
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "automatedDecisionMaking";
	dcterms:description "Information about automated decision-making, including profiling, as required by GDPR Article 22.";
	dcterms:valid "start=2026-07-17;";
	dcterms:creator "Federico Gutt";
.
