@prefix ogit.Compliance:     <http://www.purl.org/ogit/Compliance/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Compliance:program
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "program";
	dcterms:description "Name of the sanctions program (e.g. Russia, Iran, Terrorism, Narcotics).";
	dcterms:valid "start=2026-04-27;";
	dcterms:creator "chris.boos@almato.com";
.
