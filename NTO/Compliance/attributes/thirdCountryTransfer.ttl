@prefix ogit.Compliance:     <http://www.purl.org/ogit/Compliance/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Compliance:thirdCountryTransfer
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "thirdCountryTransfer";
	dcterms:description "Information about transfers of personal data to third countries or international organisations, as required by GDPR Articles 44-49.";
	dcterms:valid "start=2026-07-16;";
	dcterms:creator "Federico Gutt";
.
