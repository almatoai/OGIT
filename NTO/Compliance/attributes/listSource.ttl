@prefix ogit.Compliance:     <http://www.purl.org/ogit/Compliance/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Compliance:listSource
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "listSource";
	dcterms:description "Identifier of the sanctions list source (EU, UN, OFAC_SDN, OFAC_NON_SDN, UK).";
	dcterms:valid "start=2026-04-27;";
	dcterms:creator "chris.boos@almato.com";
.
