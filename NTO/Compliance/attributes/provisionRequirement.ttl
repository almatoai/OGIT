@prefix ogit.Compliance:     <http://www.purl.org/ogit/Compliance/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Compliance:provisionRequirement
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "provisionRequirement";
	dcterms:description "Whether the provision of personal data to the controller is a statutory or contractual requirement, as required by GDPR Articles 13(2)(e) and 14(2)(e).";
	dcterms:valid "start=2026-07-16;";
	dcterms:creator "Federico Gutt";
.
