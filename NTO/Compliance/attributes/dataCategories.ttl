@prefix ogit.Compliance:     <http://www.purl.org/ogit/Compliance/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Compliance:dataCategories
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "dataCategories";
	dcterms:description "Categories of personal data being processed, as required by GDPR Articles 13-14. Examples: name, address, health data, financial data.";
	dcterms:valid "start=2026-07-16;";
	dcterms:creator "Federico Gutt";
.
