@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .
@prefix ogit.Academy:           <http://www.purl.org/ogit/Academy/> .

ogit.Academy:scoreMax
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "scoreMax";
	dcterms:description "Maximum possible score. Aligns with xAPI Result.score.max.";
	dcterms:valid "start=2026-06-25;";
	dcterms:creator "Almato AG";
.
