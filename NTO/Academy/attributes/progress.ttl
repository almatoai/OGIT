@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .
@prefix ogit.Academy:           <http://www.purl.org/ogit/Academy/> .

ogit.Academy:progress
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "progress";
	dcterms:description "Completion progress as a real number between 0 and 1 (range enforced at the application layer; OGIT has no native numeric range validator). Aligns with SCORM cmi.progress_measure.";
	dcterms:valid "start=2026-06-25;";
	dcterms:creator "Almato AG";
.
