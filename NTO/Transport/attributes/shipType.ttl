@prefix ogit.Transport:     <http://www.purl.org/ogit/Transport/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Transport:shipType
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "shipType";
	dcterms:description "Type classification of a vessel (e.g. Bulk Carrier, Tanker, Container, General Cargo, RoRo, Passenger, Fishing).";
	dcterms:valid "start=2026-04-27;";
	dcterms:creator "chris.boos@almato.com";
.
