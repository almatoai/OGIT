@prefix ogit.Transport:         <http://www.purl.org/ogit/Transport/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.Transport:flaggedBy
	a owl:ObjectProperty;
	rdfs:subPropertyOf ogit:Verb;
	rdfs:label "flaggedBy";
	dcterms:description "Indicates the flag state (country of registration) of a vessel. Flag changes over time are tracked as time series data.";
	dcterms:valid "start=2026-04-27;";
	dcterms:creator "chris.boos@almato.com";
.
