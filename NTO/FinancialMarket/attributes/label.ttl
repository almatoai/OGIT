@prefix ogit.FinancialMarket:     <http://www.purl.org/ogit/FinancialMarket/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.FinancialMarket:label
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "label";
	dcterms:description "Attribution label for a cryptocurrency wallet (e.g. OFAC Sanctioned, Ransomware, Exchange, Mixer, Scam).";
	dcterms:valid "start=2026-04-27;";
	dcterms:creator "chris.boos@almato.com";
.
