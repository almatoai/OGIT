@prefix ogit.FinancialMarket:     <http://www.purl.org/ogit/FinancialMarket/> .
@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit.FinancialMarket:totalSent
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "totalSent";
	dcterms:description "Total value sent from a cryptocurrency wallet in its native unit (BTC or ETH).";
	dcterms:valid "start=2026-04-27;";
	dcterms:creator "chris.boos@almato.com";
.
