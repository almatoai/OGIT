@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .
@prefix ogit.ServiceManagement: <http://www.purl.org/ogit/ServiceManagement/> .

ogit.ServiceManagement:cleanSubject
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "cleanSubject";
	dcterms:description "A version of the subject with automatic cleanup";
	# For ranges, see https://www.dublincore.org/specifications/dublin-core/dcmi-period/
	dcterms:valid "start=2015-05-21;";
	dcterms:creator "Patrick Roeglin";
.
