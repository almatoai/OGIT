@prefix ogit:                 <http://www.purl.org/ogit/> .
@prefix ogit.Integration:     <http://www.purl.org/ogit/Integration/> .
@prefix owl:                  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                 <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:              <http://purl.org/dc/terms/> .

ogit:usesConfig
	a owl:ObjectProperty;
	rdfs:subPropertyOf ogit:Verb;
	rdfs:label "usesConfig";
	dcterms:description "A ConnectorRun uses an immutable ConnectorRunConfigSnapshot capturing its rule set.";
	dcterms:valid "start=2026-05-21;";
	dcterms:creator "Almato AG";
	ogit:cardinality "one2one";
.
