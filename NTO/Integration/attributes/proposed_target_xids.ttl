@prefix ogit:                 <http://www.purl.org/ogit/> .
@prefix ogit.Integration:     <http://www.purl.org/ogit/Integration/> .
@prefix owl:                  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                 <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:              <http://purl.org/dc/terms/> .

ogit.Integration:proposed_target_xids
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "proposed_target_xids";
	dcterms:description "List of at least two target-vertex identifiers the split job will create from one source vertex (Identity v2 Section 7.2).";
	dcterms:valid "start=2026-05-29;";
	dcterms:creator "Almato AG";
.
