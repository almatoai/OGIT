@prefix ogit:                 <http://www.purl.org/ogit/> .
@prefix ogit.Integration:     <http://www.purl.org/ogit/Integration/> .
@prefix owl:                  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                 <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:              <http://purl.org/dc/terms/> .

ogit.Integration:proposed_value_payload
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "proposed_value_payload";
	dcterms:description "[PII-BEARING] Proposed value payload from the conflicting incoming write. If the conflicting attribute is itself PII (name, email, identifier), this payload carries that PII verbatim. Allowed only on entities under `Decisions/PII/` (the RtE target); the framework rejects writes that attach `proposed_value_payload` to an entity outside `Decisions/PII/`.";
	dcterms:valid "start=2026-05-21;";
	dcterms:creator "Almato AG";
.
