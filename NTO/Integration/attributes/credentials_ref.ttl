@prefix ogit:                 <http://www.purl.org/ogit/> .
@prefix ogit.Integration:     <http://www.purl.org/ogit/Integration/> .
@prefix owl:                  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                 <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:              <http://purl.org/dc/terms/> .

ogit.Integration:credentials_ref
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "credentials_ref";
	dcterms:description "Vault-resolvable reference to instance credentials.";
	dcterms:valid "start=2026-05-21;";
	dcterms:creator "Almato AG";
