@prefix ogit:                 <http://www.purl.org/ogit/> .
@prefix ogit.Integration:     <http://www.purl.org/ogit/Integration/> .
@prefix owl:                  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                 <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:              <http://purl.org/dc/terms/> .

ogit.Integration:ended_at
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "ended_at";
	dcterms:description "Terminal-state timestamp on a ConnectorRun. Set when the run reaches a terminal state (completed / failed / aborted). Until set, the run is open. Used by the vertex-TTL sweep to compute eligibility for hard-deletion of historical runs per operator policy.";
	dcterms:valid "start=2026-06-05;";
	dcterms:creator "Almato AG";
.
