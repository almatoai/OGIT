@prefix ogit:                 <http://www.purl.org/ogit/> .
@prefix ogit.Integration:     <http://www.purl.org/ogit/Integration/> .
@prefix owl:                  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                 <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:              <http://purl.org/dc/terms/> .

ogit.Integration:instance_status
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "instance_status";
	dcterms:description "Lifecycle state (deployed / running / paused / retired) of the instance.";
	ogit:validation-type "fixed";
	ogit:validation-parameter "deployed,running,paused,retired";
	dcterms:valid "start=2026-05-21;";
	dcterms:creator "Almato AG";
.
