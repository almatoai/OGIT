@prefix ogit:                 <http://www.purl.org/ogit/> .
@prefix ogit.Integration:     <http://www.purl.org/ogit/Integration/> .
@prefix owl:                  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                 <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:              <http://purl.org/dc/terms/> .

ogit.Integration:canonical_value_set_ref
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "canonical_value_set_ref";
	dcterms:description "[DENORMALISED-CACHE] String reference to a CanonicalValueSet for value-drift detection (Identity v2 Sec 27). The authoritative reference is the `bindsToCanonicalValues -> CanonicalValueSet` edge on MappingRule; this attribute is a denormalised cache of the edge target's stable identifier to keep mapping-blueprint lookups single-hop. The framework re-derives the attribute from the edge whenever the edge changes; consumers MUST treat the edge as source of truth when the two diverge.";
	dcterms:valid "start=2026-05-21;";
	dcterms:creator "Almato AG";
.
