@prefix ogit:                 <http://www.purl.org/ogit/> .
@prefix ogit.Integration:     <http://www.purl.org/ogit/Integration/> .
@prefix owl:                  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                 <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:              <http://purl.org/dc/terms/> .

ogit.Integration:time_window_seconds
	a owl:DatatypeProperty;
	rdfs:subPropertyOf ogit:Attribute;
	rdfs:label "time_window_seconds";
	dcterms:description "Window length in seconds for the time_window_bounded strategy. Writes within this window are reconciled by the time_window_inner_strategy; outside the window the more-recent write wins.";
	dcterms:valid "start=2026-05-21;";
	dcterms:creator "Almato AG";
.
