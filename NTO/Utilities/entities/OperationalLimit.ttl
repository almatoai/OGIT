@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.NetworkCodes:   <http://www.purl.org/ogit/Utilities/Electricity/NetworkCodes/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities:OperationalLimit
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "OperationalLimit";
    dcterms:description "ABSTRACT: Cross-domain limit envelope. CIM 61970 has OperationalLimit and OperationalLimitSet; the generic abstraction lifts gas pressure limits, water flow limits, heat transfer limits to the same shape. Concrete typed limits (CurrentLimit, VoltageLimit, ApparentPowerLimit, ActivePowerLimit, FrequencyLimit) live in Electricity sub-namespaces.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:limit_id
        ogit.Utilities:limit_kind
        ogit.Utilities:limit_value
        ogit.Utilities:limit_unit
        ogit.Utilities:limit_direction
    );
    ogit:optional-attributes (
        ogit.Utilities:acceptable_duration
        ogit.Utilities:apparent_limit_kind
        ogit.Utilities:season
        ogit.Utilities:time_period
        ogit.Utilities:subject_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities:limit_id
    );
    ogit:allowed (
        [ ogit.Utilities:applicableTo  ogit.Utilities.Electricity:PowerSystemResource ]
        [ ogit.Utilities:partOfLimitSet  ogit.Utilities.Electricity:OperationalLimitSet ]
        [ ogit.Utilities:definedBy  ogit.Utilities.Electricity.NetworkCodes:NetworkCodeReference ]
    );
.
