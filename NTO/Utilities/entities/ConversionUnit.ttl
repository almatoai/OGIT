@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities:ConversionUnit
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ConversionUnit";
    dcterms:description "Generic energy-carrier conversion device. Sector-coupling primitive: an electrolyser (electricity to hydrogen), a fuel cell (hydrogen to electricity), a heat pump (electricity to district heat), a Power-to-X facility. Distinct from GeneratingUnit because conversion can be bidirectional and may not produce electricity. For electricity-primary cases GeneratingUnit and EnergyStorage are used; ConversionUnit covers the non-electricity-primary cases. Concrete parametric class: subtype discrimination is via the `conversionKind` enum (electrolyser, fuel_cell, heat_pump, power_to_methane, power_to_methanol, power_to_ammonia, district_heat_chiller, biomass_gasifier), not via subclassing -- consistent with the Dynamics-class parametric pattern. Discovery edges: `Utilities.Electricity:PowerPlant` consistsOf this unit (when integrated in a multi-unit facility), `OwnershipShare.sharedOf` references it, `GreenhouseGasEmission.attributedTo` points at it.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:unitId
        ogit:name
        ogit.Utilities:conversionKind
        ogit.Utilities:inputCarrierRef
        ogit.Utilities:outputCarrierRef
    );
    ogit:optional-attributes (
        ogit.Utilities:bidirectional
        ogit.Utilities:ratedPInputMw
        ogit.Utilities:ratedPOutputMw
        ogit.Utilities:nominalEfficiency
        ogit.Utilities:commissioningYear
        ogit:status
    );
    ogit:indexed-attributes (
        ogit.Utilities:unitId
    );
    ogit:allowed (
        [ ogit:consumes  ogit.Utilities:EnergyCarrier ]
        [ ogit:produces  ogit.Utilities:EnergyCarrier ]
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit.Utilities:emits  ogit.Utilities.Emissions:GreenhouseGasEmission ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
