@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities:NetworkOperator
    a rdfs:Class;
    rdfs:subClassOf sgo:Organization;
    rdfs:label "NetworkOperator";
    dcterms:description "An organisation that operates, owns, or balances a utility network. For electricity: TSO / DSO / ISO / BSP / BRP / market-coupling operator. Cross-domain equivalents in gas (DSO-G, TSO-G), district heat, hydrogen, water. Identified by ENTSO-E EIC (X-code) for electricity, DVGW number for gas, regulator-issued id for water/heat.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:operatorName
        ogit.Utilities:operatorEic
        ogit.Utilities:domain
    );
    ogit:optional-attributes (
        ogit.Utilities:operatorType
        ogit.Utilities:countryIso2
        ogit.Utilities:parentOrganizationRef
        ogit.Utilities:legalForm
        ogit.Utilities:regulatorAuthority
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities:operatorEic
        ogit.Utilities:operatorName
    );
    ogit:allowed (
        [ sgo:manages  sgo:Process ]
        [ sgo:employs  sgo:Person ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit:contains  ogit:Entity ]
        [ sgo:supports  ogit:Entity ]
        [ sgo:owns  sgo:Asset ]
        [ sgo:hasParent  sgo:Organization ]
        [ ogit.Utilities:operates  ogit.Utilities.Electricity:PowerPlant ]
        [ ogit.Utilities:responsibleFor  ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities:participates  ogit.Utilities.Electricity:SynchronousArea ]
    );
.
