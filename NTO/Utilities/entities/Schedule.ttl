@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Markets:        <http://www.purl.org/ogit/Utilities/Electricity/Markets/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities:Schedule
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "Schedule";
    dcterms:description "ABSTRACT: Generic top-level schedule. CIM has many Schedule-like classes (BasicIntervalSchedule, RegularIntervalSchedule, MarketSchedule, OutageSchedule); they all share the same meta-data shape (kind, validity window, granularity) plus an attached sgo:Timeseries carrying the actual sequence of timestamped values. Concrete schedule subtypes live in Electricity.Operations and Electricity.Markets.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:schedule_id
        ogit.Utilities:schedule_kind
        ogit.Utilities:valid_from
        ogit.Utilities:valid_until
        ogit.Utilities:granularity_seconds
    );
    ogit:optional-attributes (
        ogit.Utilities:time_zone
        ogit.Utilities:currency
        ogit.Utilities:unit_of_quantity
        ogit.Utilities:revision_number
        ogit.Utilities:published_by
        ogit.Utilities:accepted_by
    );
    ogit:indexed-attributes (
        ogit.Utilities:schedule_id
    );
    ogit:allowed (
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity.Markets:ControlArea ]
        [ ogit.Utilities:supersedes  ogit.Utilities:Schedule ]
        [ ogit.Utilities:generates  sgo:Timeseries ]
    );
.
