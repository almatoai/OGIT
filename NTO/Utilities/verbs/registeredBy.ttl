@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities:registeredBy
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "registeredBy";
    dcterms:description "Market-side registration relation. Asserts that the source entity (typically a ReserveUnit, BalancingResource, MarketableUnit) is registered for market participation by the target MarketParticipant or BalancingServiceProvider. Distinct from `operatedBy` (operational responsibility on the NetworkOperator side). Cardinality: many2one.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
