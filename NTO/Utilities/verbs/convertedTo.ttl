@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities:convertedTo
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "convertedTo";
    dcterms:description "Asserts a cross-carrier conversion path: source EnergyCarrier can be transformed into target EnergyCarrier via some ConversionUnit. Sector-coupling vocabulary. Cardinality: many2many.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
.
