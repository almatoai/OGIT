@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities:operatedBy
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "operatedBy";
    dcterms:description "Inverse of operates. Asserts that the source entity is operated by the target NetworkOperator. Range is intentionally restricted to `Utilities:NetworkOperator` -- a MarketParticipant is not a valid target for operatedBy even though both inherit from `sgo:Organization`. Market responsibility (offering / settlement) is expressed by `Utilities.Electricity.Market:submits` from the participant side, not by an inverse operatedBy. Cardinality: many2one.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
