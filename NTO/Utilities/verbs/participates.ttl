@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities:participates
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "participates";
    dcterms:description "Operator-side participation relation: a NetworkOperator participates in a SynchronousArea, ENTSO-E, Regional Security Coordinator, balancing-market platform. Distinct from `Utilities.Electricity:memberOf` (many2one) which is used by reified *Membership anchors to point at a single group with full lifecycle attributes. Cardinality: many2many.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
.
