@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol:FileTransferCommand
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "FileTransferCommand";
    dcterms:description "IEC 60870-5-101/104 ASDU 120-127. File-transfer application service. NOT a subtype of DataPoint because file-transfer ASDUs address a file at the ProtocolEndpoint level, not a per-IOA sample.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol:commandId
        ogit.Utilities.Electricity.Telecontrol:endpointRef
        ogit.Utilities.Electricity.Telecontrol:commandKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol:fileName
        ogit.Utilities.Electricity.Telecontrol:fileLength
        ogit.Utilities.Electricity.Telecontrol:sectionLength
        ogit.Utilities.Electricity.Telecontrol:nameOfFile
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol:commandId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol:addressedAt  ogit.Utilities.Electricity.Telecontrol:ProtocolEndpoint ]
    );
.
