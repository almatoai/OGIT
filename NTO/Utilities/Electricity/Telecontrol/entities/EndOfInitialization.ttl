@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol:EndOfInitialization
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Telecontrol:SystemAsdu;
    rdfs:label "EndOfInitialization";
    dcterms:description "IEC 60870-5-101/104 ASDU 70 (M_EI_NA_1). Emitted by a controlled station to signal that initialisation finished.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol:asduId
        ogit.Utilities.Electricity.Telecontrol:endpointRef
        ogit.Utilities.Electricity.Telecontrol:asduTypeId
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol:coiKind
        ogit.Utilities.Electricity.Telecontrol:cotSizeOctets
        ogit.Utilities.Electricity.Telecontrol:cotValue
        ogit.Utilities.Electricity.Telecontrol:qoiValue
        ogit.Utilities.Electricity.Telecontrol:qcc
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol:asduId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol:addressedAt  ogit.Utilities.Electricity.Telecontrol:ProtocolEndpoint ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
