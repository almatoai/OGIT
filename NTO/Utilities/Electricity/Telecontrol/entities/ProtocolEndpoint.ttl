@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol:ProtocolEndpoint
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ProtocolEndpoint";
    dcterms:description "IEC 60870-5-101/104 link-layer station. Network identity of one telecontrol station. Carries protocol kind, transport, COT / common-address / IOA size, and the controlling/controlled role.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol:endpointId
        ogit.Utilities.Electricity.Telecontrol:protocolKind
        ogit.Utilities.Electricity.Telecontrol:commonAddress
        ogit.Utilities.Electricity.Telecontrol:transport
        ogit.Utilities.Electricity.Telecontrol:endpointRole
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol:host
        ogit.Utilities.Electricity.Telecontrol:port
        ogit.Utilities.Electricity.Telecontrol:serialLink
        ogit.Utilities.Electricity.Telecontrol:timeZoneOffsetSeconds
        ogit.Utilities.Electricity.Telecontrol:cotSizeOctets
        ogit.Utilities.Electricity.Telecontrol:commonAddressSizeOctets
        ogit.Utilities.Electricity.Telecontrol:ioaSizeOctets
        ogit.Utilities.Electricity.Telecontrol:connectedToEndpointRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol:endpointId
    );
    ogit:allowed (
        [ ogit.Utilities:operatedBy  ogit.Utilities.Electricity.Telecontrol:RTU ]
        [ ogit.Utilities:operatedBy  ogit.Utilities.Electricity.Telecontrol:IED ]
        [ ogit.Utilities.Electricity.Telecontrol:belongsTo  ogit.Utilities.Electricity.Grid:Substation ]
        [ ogit.Utilities.Electricity.Telecontrol:belongsTo  ogit.Utilities:ControlCenter ]
        [ ogit.Utilities.Electricity.Telecontrol:pairsWith  ogit.Utilities.Electricity.Telecontrol:ProtocolEndpoint ]
    );
.
