@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol:SingleCommand
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Telecontrol:DataPoint;
    rdfs:label "SingleCommand";
    dcterms:description "IEC 60870-5-101/104 ASDU 45, 58. Single-point command.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol:pointId
        ogit.Utilities.Electricity.Telecontrol:endpointRef
        ogit.Utilities.Electricity.Telecontrol:commonAddress
        ogit.Utilities.Electricity.Telecontrol:informationObjectAddress
        ogit.Utilities.Electricity.Telecontrol:asduTypeId
        ogit.Utilities.Electricity.Telecontrol:pointDirection
        ogit.Utilities.Electricity.Telecontrol:qocSelectExecuteKind
        ogit.Utilities.Electricity.Telecontrol:qocQualifier
    );
    ogit:optional-attributes (

    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol:pointId
    );
    ogit:allowed (
        [ ogit:generates  sgo:Timeseries ]
    );
.
