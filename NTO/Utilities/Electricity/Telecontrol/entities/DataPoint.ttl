@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol:DataPoint
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "DataPoint";
    dcterms:description "ABSTRACT: Abstract parent of the typed monitor / control / parameter / protection points. Carries the protocol-level addressing (Common Address, IOA, ASDU type, scaling, unit, quality-flag template). The actual sample stream (values + per-sample quality flags + CP56Time2a) lives in TSDB on a sgo:Timeseries vertex attached via generates.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol:point_id
        ogit.Utilities.Electricity.Telecontrol:endpoint_ref
        ogit.Utilities.Electricity.Telecontrol:common_address
        ogit.Utilities.Electricity.Telecontrol:information_object_address
        ogit.Utilities.Electricity.Telecontrol:asdu_type_id
        ogit.Utilities.Electricity.Telecontrol:point_direction
    );
    ogit:optional-attributes (
        ogit.Utilities:subject_ref
        ogit.Utilities.Electricity:description_text
        ogit.Utilities.Electricity.Telecontrol:quality_descriptor_template
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol:point_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol:addressedAt  ogit.Utilities.Electricity.Telecontrol:ProtocolEndpoint ]
        [ ogit.Utilities.Electricity.Telecontrol:generates  sgo:Timeseries ]
    );
.
