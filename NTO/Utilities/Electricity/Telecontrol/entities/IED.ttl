@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol:IED
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "IED";
    dcterms:description "Intelligent electronic device. Distinct from RTU because IEDs additionally implement protection logic and often speak IEC 61850 / MMS as well as IEC 60870-5.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol:ied_id
        ogit.Utilities.Electricity.Grid:manufacturer
        ogit.Utilities.Electricity.Grid:model
        ogit.Utilities.Electricity.Telecontrol:ied_function
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:firmware_version
        ogit.Utilities.Electricity.Telecontrol:iec_61850_supported
        ogit.Utilities.Electricity.Telecontrol:protection_functions_payload
        ogit.Utilities:commissioning_year
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol:ied_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol:locatedIn  ogit.Utilities.Electricity.Grid:Substation ]
        [ ogit.Utilities.Electricity.Telecontrol:locatedIn  ogit.Utilities.Electricity.Grid:Bay ]
        [ ogit.Utilities.Electricity.Telecontrol:runs  ogit.Utilities.Electricity.Telecontrol:ProtocolEndpoint ]
        [ ogit.Utilities.Electricity.Telecontrol:protects  ogit.Utilities.Electricity.Grid:ACLineSegment ]
    );
.
