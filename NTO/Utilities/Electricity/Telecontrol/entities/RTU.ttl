@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol:RTU
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "RTU";
    dcterms:description "IEC 60870-5-101 station -- physical or virtual remote terminal unit. CIM AuxiliaryEquipment; modelled here as a PowerSystemResource subtype with its own typed attributes.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol:rtuId
        ogit:manufacturer
        ogit:model
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:firmwareVersion
        ogit:serialNumber
        ogit.Utilities:commissioningYear
        ogit.Utilities.Electricity.Telecontrol:subjectSubstationRef
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity:aliasName
        ogit.Utilities.Electricity:categoryRef
        ogit.Utilities:commissioningDate
        ogit.Utilities:decommissioningDate
        ogit.Utilities.Electricity:psrType
        ogit.Utilities.Electricity:externalRefs
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol:rtuId
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:allowed (
        [ ogit:locatedIn  ogit.Utilities.Electricity.Grid:Substation ]
        [ ogit.Utilities.Electricity.Telecontrol:runs  ogit.Utilities.Electricity.Telecontrol:ProtocolEndpoint ]
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
    );
.
