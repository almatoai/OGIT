@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Telecontrol.InterControlCenter:dataType
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "dataType";
    dcterms:description "TASE.2 data type per IEC 60870-6-503 (Conformance Block 1): single, double, discrete, real, state, stateSupplemental. The `stateSupplemental` value is the CIM/TASE.2-binding-document camelCase form of the IEC 60870-6-503 `STATESUP` Conformance-Block-2 supplementary data type.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "single,double,discrete,real,state,stateSupplemental";
.
