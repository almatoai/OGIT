@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Telecontrol.InterControlCenter:belongsTo
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "belongsTo";
    dcterms:description "Containment relation inside the InterControlCenter sub-namespace: a TransferReport belongs to its parent DataSetTransferSet; an AuthenticationRecord belongs to its parent Account. Distinct from `Utilities.Electricity.Operations.StateEstimation:belongsTo` (Measurement-value containment) -- separate verbs by sub-namespace because OGIT-allowed is per-class and the semantics are independent. Cardinality: many2one.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
.
