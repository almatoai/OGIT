@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:Association
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "Association";
    dcterms:description "TASE.2 Association (MMS connection between two parties).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:association_id
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:local_party_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:remote_party_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:assoc_state
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:established_at
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:released_at
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transport_endpoint_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tase_version
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:association_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:connects  ogit.Utilities:ControlCenter ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:governedBy  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:BilateralTable ]
    );
.
