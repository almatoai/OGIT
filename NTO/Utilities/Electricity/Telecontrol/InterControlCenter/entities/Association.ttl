@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:Association
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "Association";
    dcterms:description "TASE.2 Association (MMS connection between two parties).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:associationId
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:localPartyRef
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:remotePartyRef
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:assocState
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:establishedAt
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:releasedAt
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transportEndpointRef
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseVersion
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:associationId
    );
    ogit:allowed (
        [ ogit:connects  ogit.Utilities:ControlCenter ]
        [ ogit.Utilities.Electricity:governedBy  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:BilateralTable ]
    );
.
