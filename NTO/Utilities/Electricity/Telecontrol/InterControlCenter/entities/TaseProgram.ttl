@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:TaseProgram
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "TaseProgram";
    dcterms:description "TASE.2 Block 6 Program Object. Server-side program that the controlling station can request to start, stop, suspend, or resume on the controlled station.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:programId
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:parentTableRef
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:programName
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:programState
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:lastStartedAt
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:lastStoppedAt
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:programArgumentPayloadRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:programId
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:BilateralTable ]
        [ ogit:runsOn  ogit.Utilities:ControlCenter ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
