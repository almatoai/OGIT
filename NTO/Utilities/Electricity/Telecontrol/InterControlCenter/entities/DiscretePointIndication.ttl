ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DiscretePointIndication
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Telecontrol.InterControlCenter:IndicationPoint;
    rdfs:label "DiscretePointIndication";
    dcterms:description "TASE.2 Discrete Indication. Integer-valued.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tase_point_id
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:parent_dataset_member_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:data_type
    );
    ogit:optional-attributes (

    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tase_point_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:generates  sgo:Timeseries ]
    );
