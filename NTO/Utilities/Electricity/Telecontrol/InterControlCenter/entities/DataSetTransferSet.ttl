@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSetTransferSet
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "DataSetTransferSet";
    dcterms:description "TASE.2 DSTransferSet. Defines when and how a DataSet is transferred (periodic, on change, on integrity, on request).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transferId
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:datasetRef
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transferMode
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:intervalSeconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:blockData
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:eventCodeRequested
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tsStartTime
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tsStopTime
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transferSetName
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transferId
    );
    ogit:allowed (
        [ ogit:governs  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSet ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
