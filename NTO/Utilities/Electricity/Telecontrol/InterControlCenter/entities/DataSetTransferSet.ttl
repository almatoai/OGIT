@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSetTransferSet
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "DataSetTransferSet";
    dcterms:description "TASE.2 DSTransferSet. Defines when and how a DataSet is transferred (periodic, on change, on integrity, on request).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transfer_id
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:dataset_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transfer_mode
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:interval_seconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:block_data
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:event_code_requested
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:ts_start_time
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:ts_stop_time
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transfer_set_name
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:transfer_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:governs  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSet ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:generates  sgo:Timeseries ]
    );
.
