@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:AuthenticationRecord
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "AuthenticationRecord";
    dcterms:description "TASE.2 authentication exchanges over the connection. An audit anchor for sessions; the per-event sequence lives as sgo:Timeseries.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseRecordId
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:parentAccountRef
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:lastAuthenticatedAt
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:authenticationMethod
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:sessionDurationSeconds
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseRecordId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:belongsTo  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:Account ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
