@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:MmsObjectReference
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "MmsObjectReference";
    dcterms:description "ISO 9506 (MMS) Object Reference, the underlying naming for TASE.2 objects.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:ref_id
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:domain_name
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:item_name
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:vmd_name
        ogit.Utilities.Electricity:description_text
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:ref_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:identifies  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:IndicationPoint ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:identifies  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSet ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:identifies  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSetTransferSet ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:identifies  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DeviceTag ]
    );
.
