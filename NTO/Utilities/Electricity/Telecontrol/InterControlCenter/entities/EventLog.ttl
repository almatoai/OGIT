@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:EventLog
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "EventLog";
    dcterms:description "TASE.2 Block 7 Event Service. Persistent event log carried over the inter-center link. Anchor + sgo:Timeseries: the vertex holds the log identity; the individual log entries are TSDB entries.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:log_id
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:parent_table_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:log_kind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:retention_days
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:last_event_at
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:event_count_per_day
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:log_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:partOf  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:BilateralTable ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:generates  sgo:Timeseries ]
    );
.
