@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:EventLog
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "EventLog";
    dcterms:description "TASE.2 Block 7 Event Service. Persistent event log carried over the inter-center link. Anchor + sgo:Timeseries: the vertex holds the log identity; the individual log entries are TSDB entries.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:logId
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:parentTableRef
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:logKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:retentionDays
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:lastEventAt
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:eventCountPerDay
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:logId
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:BilateralTable ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
