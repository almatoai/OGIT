@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations.StateEstimation: <http://www.purl.org/ogit/Utilities/Electricity/Operations/StateEstimation/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:IndicationPoint
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "IndicationPoint";
    dcterms:description "ABSTRACT: TASE.2 IndicationPoint. Abstract parent of TASE.2 typed points (single, double, discrete, real, state).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tasePointId
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:parentDatasetMemberRef
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:dataType
    );
    ogit:optional-attributes (
        ogit:name
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseUnit
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseScale
        ogit.Utilities.Electricity.Operations.StateEstimation:powerSystemResourceRef
        ogit.Utilities.Electricity:descriptionText
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tasePointId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:referencedBy  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSetMember ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:mirrors  ogit.Utilities.Electricity.Telecontrol:DataPoint ]
        [ ogit:generates  ogit:Timeseries ]
    );
.
