@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:TransferReport
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "TransferReport";
    dcterms:description "TASE.2 Transfer Report. The actual report message of one DataSetTransferSet trigger. The parent DataSetTransferSet is expressed via the `belongsTo -> DataSetTransferSet` graph edge; no parallel `parentTransferSetRef` attribute.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:reportId
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:reportTime
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:eventCode
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:datasetPayloadRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:reportId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:belongsTo  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSetTransferSet ]
    );
.
