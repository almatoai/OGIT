@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:TransferReport
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "TransferReport";
    dcterms:description "TASE.2 Transfer Report. The actual report message of one DataSetTransferSet trigger.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:report_id
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:parent_transfer_set_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:report_time
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:event_code
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:dataset_payload_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:report_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:belongsTo  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSetTransferSet ]
    );
.
