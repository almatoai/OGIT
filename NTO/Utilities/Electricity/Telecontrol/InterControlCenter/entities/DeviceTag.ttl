@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DeviceTag
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "DeviceTag";
    dcterms:description "TASE.2 Device Tag. Operator-applied tag (work permit, do-not-operate, hot-line orders).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tag_id
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:referenced_point_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tag_kind
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:applied_at
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:applied_by_ref
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:cleared_at
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:cleared_by_ref
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:reason
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:tag_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:appliedToIndication  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:IndicationPoint ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:appliedToIndication  ogit.Utilities.Electricity.Grid:Switch ]
        [ ogit.Utilities.Electricity.Telecontrol.InterControlCenter:appliedBy  ogit.Utilities:NetworkOperator ]
    );
.
