@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol.InterControlCenter: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/InterControlCenter/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSetMember
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "DataSetMember";
    dcterms:description "TASE.2 DataSet member entry.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseMemberId
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:parentDatasetRef
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseMemberPosition
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:referencedPointRef
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseMemberType
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Telecontrol.InterControlCenter:taseMemberId
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DataSet ]
        [ ogit:references  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:IndicationPoint ]
        [ ogit:references  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:TaseProtectionEquipment ]
        [ ogit:references  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:DeviceTag ]
        [ ogit:references  ogit.Utilities.Electricity.Telecontrol.InterControlCenter:ConditionVariable ]
    );
.
