@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Telecontrol:    <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Telecontrol:belongsTo
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "belongsTo";
    dcterms:description "Containment relation inside the Telecontrol sub-namespace: a ProtocolEndpoint belongs to a parent Substation or ControlCenter. Distinct from the homonymous verbs in StateEstimation and InterControlCenter -- OGIT-allowed is per-class and each sub-namespace declares its own verb with its own semantics. Cardinality: many2one.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
.
