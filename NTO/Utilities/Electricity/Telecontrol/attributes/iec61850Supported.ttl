ogit.Utilities.Electricity.Telecontrol:iec61850Supported
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "iec61850Supported";
    dcterms:description "Boolean. True if the IED implements IEC 61850 services (MMS, GOOSE, SMV).";
