@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Legacy:         <http://www.purl.org/ogit/Utilities/Electricity/Legacy/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Legacy:statusCode
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "statusCode";
    dcterms:description "UCTE node status indicator. The wire-format is a 1-character code in the source UCTE-DEF file; this attribute carries the mnemonic expansion: real (R), equivalent (E), busbar_coupler_in_operation (B closed), busbar_coupler_out_of_operation (B open). Mapping from the 1-character code to the mnemonic happens in the parser.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "real,equivalent,busbar_coupler_in_operation,busbar_coupler_out_of_operation";
.
