@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Legacy:         <http://www.purl.org/ogit/Utilities/Electricity/Legacy/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Legacy:UcteDcLink
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "UcteDcLink";
    dcterms:description "UCTE-DEF DC record. HVDC link between two UcteNodes. Maps forward to a CGMES DCLineSegment plus the associated converters (CsConverter or VsConverter).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Legacy:recordId
        ogit.Utilities.Electricity.Legacy:nodeARef
        ogit.Utilities.Electricity.Legacy:nodeBRef
        ogit.Utilities.Electricity.Legacy:linkId
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Legacy:ratedPowerMw
        ogit.Utilities.Electricity.Grid:ratedVoltageKv
        ogit.Utilities.Electricity.Legacy:operatingMode
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Legacy:recordId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Legacy:mappedTo  ogit.Utilities.Electricity.Grid:DCLineSegment ]
        [ ogit.Utilities.Electricity.Legacy:mappedTo  ogit.Utilities.Electricity.Grid:CsConverter ]
        [ ogit.Utilities.Electricity.Legacy:mappedTo  ogit.Utilities.Electricity.Grid:VsConverter ]
        [ ogit:connects  ogit.Utilities.Electricity.Legacy:UcteNode ]
    );
.
