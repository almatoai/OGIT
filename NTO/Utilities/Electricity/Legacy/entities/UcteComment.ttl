@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Legacy:         <http://www.purl.org/ogit/Utilities/Electricity/Legacy/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Legacy:UcteComment
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "UcteComment";
    dcterms:description "UCTE-DEF C record. Comment / free-text annotation line in the source file. Mostly metadata; carried over so a connector can preserve provenance and operator notes. Variant records (S Switched-line status, C_T transformer-coupling) used by some PSS/E-based exporters are also mapped here with `variantRecordKind` set so downstream consumers can distinguish them from genuine comments.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Legacy:recordId
        ogit.Utilities.Electricity.Legacy:text
        ogit.Utilities.Electricity.Legacy:sourceFileRef
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Legacy:variantRecordKind
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Legacy:recordId
    );
    ogit:allowed (

    );
.
