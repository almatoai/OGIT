    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Legacy:record_id
        ogit.Utilities.Electricity.Legacy:text
        ogit.Utilities.Electricity.Legacy:source_file_ref
    );
