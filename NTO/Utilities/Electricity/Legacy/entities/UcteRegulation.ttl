@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Legacy:         <http://www.purl.org/ogit/Utilities/Electricity/Legacy/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Legacy:UcteRegulation
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "UcteRegulation";
    dcterms:description "UCTE-DEF R record. Tap-changer regulation parameters. Maps forward to a CGMES RatioTapChanger or PhaseTapChanger depending on regulation_kind.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Legacy:record_id
        ogit.Utilities.Electricity.Legacy:parent_transformer_ref
        ogit.Utilities.Electricity.Legacy:regulation_kind
        ogit.Utilities.Electricity.Legacy:tap_position
        ogit.Utilities.Electricity.Legacy:tap_step_count
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Legacy:regulation_step_kv
        ogit.Utilities.Electricity.Legacy:regulation_min_kv
        ogit.Utilities.Electricity.Legacy:regulation_max_kv
        ogit.Utilities.Electricity.Legacy:target_node_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Legacy:record_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Legacy:appliesTo  ogit.Utilities.Electricity.Legacy:UcteTwoWindingTransformer ]
        [ ogit.Utilities.Electricity.Legacy:appliesTo  ogit.Utilities.Electricity.Legacy:UcteThreeWindingTransformer ]
        [ ogit.Utilities.Electricity.Legacy:mappedTo  ogit.Utilities.Electricity.Grid:RatioTapChanger ]
        [ ogit.Utilities.Electricity.Legacy:mappedTo  ogit.Utilities.Electricity.Grid:PhaseTapChanger ]
    );
.
