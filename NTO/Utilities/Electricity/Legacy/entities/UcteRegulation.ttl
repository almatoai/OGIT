@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Legacy:         <http://www.purl.org/ogit/Utilities/Electricity/Legacy/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Legacy:UcteRegulation
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "UcteRegulation";
    dcterms:description "UCTE-DEF R record. Tap-changer regulation parameters. Maps forward to a CGMES RatioTapChanger or PhaseTapChanger depending on regulation_kind.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Legacy:recordId
        ogit.Utilities.Electricity.Legacy:parentTransformerRef
        ogit.Utilities.Electricity.Legacy:regulationKind
        ogit.Utilities.Electricity.Legacy:tapPosition
        ogit.Utilities.Electricity.Legacy:tapStepCount
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Legacy:regulationStepKv
        ogit.Utilities.Electricity.Legacy:regulationMinKv
        ogit.Utilities.Electricity.Legacy:regulationMaxKv
        ogit.Utilities.Electricity.Legacy:targetNodeRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Legacy:recordId
    );
    ogit:allowed (
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity.Legacy:UcteTwoWindingTransformer ]
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity.Legacy:UcteThreeWindingTransformer ]
        [ ogit.Utilities.Electricity.Legacy:mappedTo  ogit.Utilities.Electricity.Grid:RatioTapChanger ]
        [ ogit.Utilities.Electricity.Legacy:mappedTo  ogit.Utilities.Electricity.Grid:PhaseTapChanger ]
    );
.
