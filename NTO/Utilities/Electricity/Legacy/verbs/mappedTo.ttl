@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Legacy:         <http://www.purl.org/ogit/Utilities/Electricity/Legacy/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Legacy:mappedTo
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "mappedTo";
    dcterms:description "Asserts that a Legacy UCTE-DEF record maps forward to one or more CGMES-conformant Grid classes. Cardinality is many-to-many because a single UCTE record may produce multiple CGMES vertices (e.g. a UcteTwoWindingTransformer produces a PowerTransformer plus two PowerTransformerEnds). Cardinality: many2many.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
.
