@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:SteamTurbineGovernor
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Dynamics:TurbineGovernorDynamics;
    rdfs:label "SteamTurbineGovernor";
    dcterms:description "Steam-turbine governor dynamic model. Adds governor_kind plus HP/IP/LP section counts.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Dynamics:synchronousMachineDynamicsRef
        ogit.Utilities.Electricity.Dynamics:modelKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:governorKind
        ogit.Utilities.Electricity.Dynamics:hpSection
        ogit.Utilities.Electricity.Dynamics:ipSection
        ogit.Utilities.Electricity.Dynamics:lpSectionCount
        ogit.Utilities.Electricity.Dynamics:parameterPayload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (

    );
.
