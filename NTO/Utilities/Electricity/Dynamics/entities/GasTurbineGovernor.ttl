@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:GasTurbineGovernor
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "GasTurbineGovernor";
    dcterms:description "Gas-turbine governor dynamic model. The equipment-side `cycleKind` (single-cycle vs CCGT) lives on the linked `ThermalGeneratingUnit` vertex, not here -- this class only carries governor-dynamics parameters.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Dynamics:synchronousMachineDynamicsRef
        ogit.Utilities.Electricity.Dynamics:modelKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:frequencyDroopPercent
        ogit.Utilities.Electricity.Dynamics:parameterPayload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity.Dynamics:SynchronousMachineDynamics ]
    );
.
