@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:MechanicalLoadDynamics
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "MechanicalLoadDynamics";
    dcterms:description "CIM cim:MechanicalLoadDynamics. Driven-mechanical-load model for motor analyses.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Dynamics:asynchronousMachineDynamicsRef
        ogit.Utilities.Electricity.Dynamics:modelKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:parameterPayload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity.Dynamics:AsynchronousMachineDynamics ]
    );
.
