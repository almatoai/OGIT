@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:StabilityModel
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "StabilityModel";
    dcterms:description "Full system-stability model bundle.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Dynamics:model_id
        ogit:name
        ogit.Utilities.Electricity.Dynamics:target_synchronous_area_ref
        ogit.Utilities.Electricity.Dynamics:stability_version
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:tool_specific_format
        ogit.Utilities:valid_from
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Dynamics:model_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Dynamics:consistsOf  ogit.Utilities.Electricity.Dynamics:SynchronousMachineDynamics ]
        [ ogit.Utilities.Electricity.Dynamics:consistsOf  ogit.Utilities.Electricity.Dynamics:ExcitationSystemDynamics ]
        [ ogit.Utilities.Electricity.Dynamics:consistsOf  ogit.Utilities.Electricity.Dynamics:TurbineGovernorDynamics ]
        [ ogit.Utilities.Electricity.Dynamics:consistsOf  ogit.Utilities.Electricity.Dynamics:LoadDynamics ]
        [ ogit.Utilities.Electricity.Dynamics:consistsOf  ogit.Utilities.Electricity.Dynamics:HvdcDynamics ]
    );
.
