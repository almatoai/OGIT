ogit.Utilities.Electricity.Dynamics:LoadStaticConstantPower
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Dynamics:LoadDynamics;
    rdfs:label "LoadStaticConstantPower";
    dcterms:description "Constant-power load model: P, Q independent of voltage.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities:subject_ref
        ogit.Utilities.Electricity.Dynamics:model_kind
    );
    ogit:optional-attributes (

    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (

    );
.
