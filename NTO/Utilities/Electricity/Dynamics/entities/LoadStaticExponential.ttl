@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:LoadStaticExponential
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Dynamics:LoadDynamics;
    rdfs:label "LoadStaticExponential";
    dcterms:description "Exponential load model: P and Q vary with voltage to fitted exponents.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities:subjectRef
        ogit.Utilities.Electricity.Dynamics:modelKind
        ogit.Utilities.Electricity.Dynamics:exponentP
        ogit.Utilities.Electricity.Dynamics:exponentQ
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:parameterPayload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Dynamics:models  ogit.Utilities.Electricity:EnergyConsumer ]
    );
.
