ogit.Utilities.Electricity.Dynamics:PowerSystemStabilizerDynamics
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "PowerSystemStabilizerDynamics";
    dcterms:description "CIM cim:PowerSystemStabilizerDynamics. PSS model (pss1a, pss2b, pss3b, pss4b, pss5, pssIEEE2B).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Dynamics:excitationSystemDynamicsRef
        ogit.Utilities.Electricity.Dynamics:modelKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:parameterPayload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (

    );
.
