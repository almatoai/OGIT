@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:LoadStaticZip
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "LoadStaticZip";
    dcterms:description "ZIP composite static load model: P = Pz V^2 + Pi V + Pp, analog for Q.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities:subjectRef
        ogit.Utilities.Electricity.Dynamics:modelKind
        ogit.Utilities.Electricity.Dynamics:pZ
        ogit.Utilities.Electricity.Dynamics:pI
        ogit.Utilities.Electricity.Dynamics:pP
        ogit.Utilities.Electricity.Dynamics:qZ
        ogit.Utilities.Electricity.Dynamics:qI
        ogit.Utilities.Electricity.Dynamics:qP
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:parameterPayload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Dynamics:models  ogit.Utilities.Electricity:EnergyConsumer ]
    );
.
