@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:AsynchronousMachineDynamics
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "AsynchronousMachineDynamics";
    dcterms:description "CIM cim:AsynchronousMachineDynamics. Induction-machine dynamic model (classical, double-cage).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Dynamics:asynchronous_machine_ref
        ogit.Utilities.Electricity.Dynamics:model_kind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:parameter_payload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Dynamics:models  ogit.Utilities.Electricity.Grid:AsynchronousMachine ]
    );
.
