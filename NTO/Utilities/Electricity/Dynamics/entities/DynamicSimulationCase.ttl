@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:DynamicSimulationCase
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "DynamicSimulationCase";
    dcterms:description "One transient-stability or EMT study run. Anchor + sgo:Timeseries: per-channel trajectory output lives in TSDB.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Dynamics:caseId
        ogit:name
        ogit.Utilities.Electricity.Dynamics:subjectSynchronousAreaRef
        ogit.Utilities.Electricity.Dynamics:simulationKind
        ogit.Utilities.Electricity.Dynamics:initialStateSnapshotRef
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:toolName
        ogit.Utilities.Electricity.Operations:toolVersion
        ogit.Utilities.Electricity.Dynamics:simulationDurationS
        ogit.Utilities.Electricity.Dynamics:timeStepMs
        ogit.Utilities.Electricity.Dynamics:resultArtifactUri
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Dynamics:caseId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Dynamics:studies  ogit.Utilities.Electricity:SynchronousArea ]
        [ ogit.Utilities.Electricity.Operations:triggeredBy  sgo:Event ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
