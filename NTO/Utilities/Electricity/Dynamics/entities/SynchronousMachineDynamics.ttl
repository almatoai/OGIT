@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Dynamics:SynchronousMachineDynamics
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "SynchronousMachineDynamics";
    dcterms:description "CIM cim:SynchronousMachineDynamics. Concrete parametric class covering all typed synchronous-machine dynamic models. modelKind selects between classical, gentpf, gentpj, genrou, genwro, gencls, gensae, gensal, genwbr, vsource_for_psse (see Ontology Reference Section 4 -- CGMES DY bijection). Per Architecture Section 11.3 the typed model variants are differentiated by the modelKind enum on the instance, not by subclassing -- consistent with the other parametric Dynamics top-level classes (ExcitationSystemDynamics, PowerSystemStabilizerDynamics, AsynchronousMachineDynamics, HvdcDynamics, FactsDynamics, WindGeneratorDynamics, SolarInverterDynamics, BatteryEnergyStorageDynamics, OverexcitationLimiterDynamics, UnderexcitationLimiterDynamics, VoltageCompensatorDynamics, MechanicalLoadDynamics, ProtectionRelayDynamics). LoadDynamics and TurbineGovernorDynamics stay abstract because they carry concrete subtypes with their own attribute shapes.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Dynamics:synchronousMachineRef
        ogit.Utilities.Electricity.Dynamics:modelKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Dynamics:parameterPayload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Dynamics:models  ogit.Utilities.Electricity.Grid:SynchronousMachine ]
    );
.
