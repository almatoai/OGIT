@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Dynamics:parameterPayload
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "parameterPayload";
    dcterms:description "JSON-encoded parameter set of the dynamic model. Per design decision the individual parameters are not flattened into typed attributes; queries that need per-parameter filtering JSON-parse on the consumer side.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
.
