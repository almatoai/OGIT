@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Dynamics:       <http://www.purl.org/ogit/Utilities/Electricity/Dynamics/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Dynamics:toolFormat
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "toolFormat";
    dcterms:description "EMT tool source format: pscad, atp, rtds, psse, powerfactory, emtp_rv, hypersim, modelica, opendss, etc. Left open because the EMT-tool landscape is vendor-driven and grows with new releases (Section 11.1a Regel 3).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
.
