ogit.Utilities.Electricity.Dynamics:turbineKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "turbineKind";
    dcterms:description "Hydro turbine kind: francis, kaplan, pelton, bulb, propeller, pump_turbine (reversible Francis-class turbine for pumped-storage units, operates as both turbine and pump).";
