@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:subscribesTo
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "subscribesTo";
    dcterms:description "Asserts that an EnergyConsumer subscribes to a Schedule (e.g. an industrial customer to a day-ahead schedule). Cardinality: many2many.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
