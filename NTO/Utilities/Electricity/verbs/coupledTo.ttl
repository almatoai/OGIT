ogit.Utilities.Electricity:coupledTo
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "coupledTo";
    dcterms:description "Asserts that two BiddingZones are market-coupled (SDAC, SIDC, regional coupling). Cardinality: many2many.";
