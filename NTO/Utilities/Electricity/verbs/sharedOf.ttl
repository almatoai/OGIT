ogit.Utilities.Electricity:sharedOf
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "sharedOf";
    dcterms:description "Reifies the asset side of an ownership relation: an OwnershipShare points (via sharedOf) at the physical asset whose ownership the share fraction describes. Cardinality: many2one.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
.
