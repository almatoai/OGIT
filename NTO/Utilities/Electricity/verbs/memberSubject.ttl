ogit.Utilities.Electricity:memberSubject
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "memberSubject";
    dcterms:description "Reifies the subject side of a membership relation: a *Membership anchor points to the subject (GeneratingUnit, EnergyStorage, EnergyConsumer, ControlArea, BiddingZone). Cardinality: many2one.";
