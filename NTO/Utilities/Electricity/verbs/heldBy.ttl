@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:heldBy
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "heldBy";
    dcterms:description "Reifies the counter-party side of an ownership relation: an OwnershipShare is held by an Organization (NetworkOperator or generic sgo:Organization). Cardinality: many2one.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
.
