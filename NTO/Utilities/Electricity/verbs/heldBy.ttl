ogit.Utilities.Electricity:heldBy
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "heldBy";
    dcterms:description "Reifies the ownership counter-party relation: an OwnershipShare is held by an organisation (NetworkOperator or generic sgo:Organization). Cardinality many2one. Used by reified OwnershipShare. See concept Section 8.1.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
.
