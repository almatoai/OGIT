@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:connectedVia
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "connectedVia";
    dcterms:description "Asserts that a ControlArea is connected to a peer ControlArea via the target Interconnector. The Interconnector then connects to the peer ControlArea; this avoids direct ControlArea-to-ControlArea edges. Cardinality: one2many.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
.
