ogit.Utilities.Electricity:memberOf
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "memberOf";
    dcterms:description "Reifies the group side of a membership relation: a *Membership anchor points to the group (ControlArea, SynchronousArea, BiddingZone). Cardinality: many2one.";
