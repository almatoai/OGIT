@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:memberOf
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "memberOf";
    dcterms:description "Reifies the group side of a membership relation: a *Membership anchor (ControlAreaMembership / SynchronousAreaMembership / BiddingZoneMembership) points to the group it represents membership in. Many memberships can point to the same group; each membership instance points to exactly one group. Distinct from `Utilities:participates` (many2many) which models direct operator-side affiliation without lifecycle anchoring. Cardinality: many2one.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
