@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:ownedBy
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "ownedBy";
    dcterms:description "Asserts that the source PowerSystemResource is legally owned by the target Organization or NetworkOperator. Distinguished from operatedBy (operational responsibility) and from heldBy on OwnershipShare (reified, share-fraction-bearing). Cardinality: many2many.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
