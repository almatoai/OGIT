@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Diagram:        <http://www.purl.org/ogit/Utilities/Electricity/Diagram/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Diagram:representsObject
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "representsObject";
    dcterms:description "Asserts that a DiagramObject represents one underlying PowerSystemResource graphically. Many DiagramObjects (in different Diagrams) can represent the same PowerSystemResource; each DiagramObject represents exactly one PowerSystemResource. Cardinality: many2one.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
.
