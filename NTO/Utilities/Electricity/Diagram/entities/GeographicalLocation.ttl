@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Diagram:        <http://www.purl.org/ogit/Utilities/Electricity/Diagram/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Diagram:GeographicalLocation
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "GeographicalLocation";
    dcterms:description "CIM cim:Location (GL profile). Geographic anchor for one or more PowerSystemResources.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Diagram:coordinateSystemRef
    );
    ogit:optional-attributes (
        ogit.Utilities:countryIso2
        ogit.Utilities.Electricity.Grid:regionRef
        ogit.Utilities.Electricity.Grid:subregionRef
        ogit.Utilities.Electricity:descriptionText
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:consistsOf  ogit.Utilities.Electricity.Diagram:PositionPoint ]
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity:PowerSystemResource ]
    );
.
