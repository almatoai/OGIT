@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Diagram:        <http://www.purl.org/ogit/Utilities/Electricity/Diagram/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Diagram:PositionPoint
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "PositionPoint";
    dcterms:description "CIM cim:PositionPoint. One 2D / 3D point in a GeographicalLocation. The parent GeographicalLocation is expressed via the `ogit:isPartOf -> GeographicalLocation` graph edge; no parallel `parentLocationRef` attribute.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity:sequenceNumber
        ogit.Utilities.Electricity.Diagram:xPosition
        ogit.Utilities.Electricity.Diagram:yPosition
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Diagram:zPosition
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity.Diagram:GeographicalLocation ]
    );
.
