@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Diagram:        <http://www.purl.org/ogit/Utilities/Electricity/Diagram/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Diagram:ColorScheme
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ColorScheme";
    dcterms:description "Extension of DL profile. Colour schemes for power-flow visualisation or other domain-specific overlays.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Diagram:scheme_id
        ogit:name
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Diagram:scheme_payload
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Diagram:scheme_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Diagram:usedBy  ogit.Utilities.Electricity.Diagram:DiagramStyle ]
    );
.
