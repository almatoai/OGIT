@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Diagram:        <http://www.purl.org/ogit/Utilities/Electricity/Diagram/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Diagram:DiagramObjectPoint
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "DiagramObjectPoint";
    dcterms:description "CIM cim:DiagramObjectPoint. A point in 2D / 3D diagram coordinates belonging to a DiagramObject (e.g. corner of a polygon).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Diagram:parent_diagram_object_ref
        ogit.Utilities.Electricity.Grid:sequence_number
        ogit.Utilities.Electricity.Diagram:x_position
        ogit.Utilities.Electricity.Diagram:y_position
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Diagram:z_position
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Diagram:partOf  ogit.Utilities.Electricity.Diagram:DiagramObject ]
    );
.
