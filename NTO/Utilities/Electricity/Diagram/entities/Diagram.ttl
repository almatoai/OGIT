@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Diagram:        <http://www.purl.org/ogit/Utilities/Electricity/Diagram/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Diagram:Diagram
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "Diagram";
    dcterms:description "CIM cim:Diagram (DL profile). A schematic diagram representation of a part of the network.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Diagram:orientation
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:description_text
        ogit.Utilities.Electricity.Diagram:diagram_version
        ogit.Utilities.Electricity.Diagram:diagram_style_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Diagram:consistsOf  ogit.Utilities.Electricity.Diagram:DiagramObject ]
        [ ogit.Utilities.Electricity.Diagram:governedBy  ogit.Utilities.Electricity.Diagram:DiagramStyle ]
    );
.
