@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Operations.Reserves:awardedStatus
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "awardedStatus";
    dcterms:description "Awarded status: fully_awarded, partially_awarded, not_awarded, withdrawn.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "fully_awarded,partially_awarded,not_awarded,withdrawn";
.
