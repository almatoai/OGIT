ogit.Utilities.Electricity.Operations.Reserves:qualifiedFcr
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "qualifiedFcr";
    dcterms:description "Boolean. True if the ReserveUnit is qualified to offer FCR (Frequency Containment Reserve per ENTSO-E NC EB).";
