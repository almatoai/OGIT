@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix ogit.Utilities.Electricity.Operations.Reserves: <http://www.purl.org/ogit/Utilities/Electricity/Operations/Reserves/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.Reserves:ReserveUnit
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ReserveUnit";
    dcterms:description "NC EB. A registered resource that can offer one or more reserve products. ReserveUnit aggregates above the equipment level for market participation.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:unitId
        ogit:name
        ogit.Utilities.Electricity.Market:participantRef
        ogit.Utilities.Electricity:controlAreaRef
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:minCapacityMw
        ogit.Utilities.Electricity.Operations.Reserves:maxCapacityMw
        ogit.Utilities.Electricity.Operations.Reserves:minRuntimeMin
        ogit.Utilities.Electricity.Operations.Reserves:minDowntimeMin
        ogit.Utilities.Electricity.Operations.Reserves:qualifiedFcr
        ogit.Utilities.Electricity.Operations.Reserves:qualifiedAfrr
        ogit.Utilities.Electricity.Operations.Reserves:qualifiedMfrr
        ogit.Utilities.Electricity.Operations.Reserves:qualifiedRr
        ogit.Utilities.Electricity.Operations.Reserves:qualificationDate
    );
    ogit:indexed-attributes (
        ogit.Utilities:unitId
    );
    ogit:allowed (
        [ ogit.Utilities:registeredBy  ogit.Utilities.Electricity:MarketParticipant ]
        [ ogit:provides  ogit.Utilities.Electricity.Operations.Reserves:FcrOffering ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:ControlArea ]
    );
.
