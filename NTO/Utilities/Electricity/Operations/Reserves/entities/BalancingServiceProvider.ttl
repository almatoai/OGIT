@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations.Reserves: <http://www.purl.org/ogit/Utilities/Electricity/Operations/Reserves/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.Reserves:BalancingServiceProvider
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "BalancingServiceProvider";
    dcterms:description "NC EB Article 18. Market role: entity offering balancing services. Subtype of MarketParticipant (which itself extends sgo:Organization), adding BSP-specific qualification metadata. Per Architecture Section 5.1g the materialised-inheritance pattern propagates over the full 3-level chain at TTL generation time: the BSP TTL carries the seven sgo:Organization-inherited verbs (sgo:manages, sgo:employs, ogit:locatedIn, ogit:contains, sgo:supports, sgo:owns, sgo:hasParent) plus the MarketParticipant-domain verbs plus the BSP-specific submit verbs. The verb list shown here is the BSP-specific delta; the full materialised set is in the generated TTL file.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:participantName
        ogit.Utilities.Electricity:participantEic
        ogit.Utilities.Electricity:roleKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:bspId
        ogit.Utilities.Electricity.Operations.Reserves:qualificationProducts
        ogit.Utilities.Electricity.Operations.Reserves:qualificationControlAreas
        ogit.Utilities:countryIso2
        ogit.Utilities:parentOrganizationRef
        ogit.Utilities.Electricity:accreditedIn
        ogit.Utilities.Electricity:accreditationStatus
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:bspId
        ogit.Utilities.Electricity:participantEic
        ogit.Utilities.Electricity:participantEic
    );
    ogit:allowed (
        [ ogit:manages  ogit:Entity ]
        [ ogit:employs  ogit:Person ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit:contains  ogit:Entity ]
        [ ogit:supports  ogit:Entity ]
        [ ogit:owns  ogit:Asset ]
        [ ogit:hasParent  ogit:Organization ]
        [ ogit.Utilities.Electricity:submits  ogit.Utilities.Electricity.Operations.Reserves:BalancingEnergyBid ]
        [ ogit.Utilities.Electricity:submits  ogit.Utilities.Electricity.Operations.Reserves:BalancingCapacityBid ]
    );
.
