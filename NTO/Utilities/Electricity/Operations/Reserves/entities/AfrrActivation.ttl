@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Operations.Reserves: <http://www.purl.org/ogit/Utilities/Electricity/Operations/Reserves/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.Reserves:AfrrActivation
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "AfrrActivation";
    dcterms:description "Time-resolved aFRR delivery anchored on a ReserveUnit. Granularity typical 4 s.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:activation_id
        ogit.Utilities.Electricity.Operations.Reserves:reserve_unit_ref
        ogit.Utilities:granularity_seconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:activation_source
        ogit.Utilities.Electricity.Operations.Reserves:setpoint_unit
        ogit.Utilities.Electricity.Operations.Reserves:setpoint_signal_source
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:activation_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations.Reserves:deliveredBy  ogit.Utilities.Electricity.Operations.Reserves:ReserveUnit ]
        [ ogit.Utilities.Electricity.Operations.Reserves:generates  sgo:Timeseries ]
    );
.
