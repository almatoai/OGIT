@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix ogit.Utilities.Electricity.Operations.Reserves: <http://www.purl.org/ogit/Utilities/Electricity/Operations/Reserves/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.Reserves:ImbalanceSettlement
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ImbalanceSettlement";
    dcterms:description "NC EB Article 49. Per-imbalance-settlement-period imbalance result per BSP / responsible party.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:settlementId
        ogit.Utilities.Electricity.Operations:responsiblePartyRef
        ogit.Utilities:periodStart
        ogit.Utilities:periodEnd
        ogit.Utilities.Electricity.Operations.Reserves:imbalanceMwh
        ogit.Utilities.Electricity.Operations.Reserves:settlePriceEurPerMwh
        ogit.Utilities.Electricity.Market:settlementCurrency
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:singlePrice
        ogit.Utilities.Electricity.Operations.Reserves:dualPriceUpEurPerMwh
        ogit.Utilities.Electricity.Operations.Reserves:dualPriceDownEurPerMwh
        ogit.Utilities.Electricity.Operations.Reserves:totalCostEur
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:settlementId
    );
    ogit:allowed (
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity.Operations.Reserves:BalancingServiceProvider ]
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity:MarketParticipant ]
        [ ogit.Utilities.Electricity.Operations.Reserves:inControlArea  ogit.Utilities.Electricity:ControlArea ]
    );
.
