@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix ogit.Utilities.Electricity.Operations.Reserves: <http://www.purl.org/ogit/Utilities/Electricity/Operations/Reserves/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.Reserves:ImbalanceSettlement
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ImbalanceSettlement";
    dcterms:description "NC EB Article 49. Per-imbalance-settlement-period imbalance result per BSP / responsible party.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:settlement_id
        ogit.Utilities.Electricity.Operations:responsible_party_ref
        ogit.Utilities.Emissions:period_start
        ogit.Utilities.Emissions:period_end
        ogit.Utilities.Electricity.Operations.Reserves:imbalance_mwh
        ogit.Utilities.Electricity.Operations.Reserves:settle_price_eur_per_mwh
        ogit.Utilities.Electricity.Market:settlement_currency
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:single_price
        ogit.Utilities.Electricity.Operations.Reserves:dual_price_up_eur_per_mwh
        ogit.Utilities.Electricity.Operations.Reserves:dual_price_down_eur_per_mwh
        ogit.Utilities.Electricity.Operations.Reserves:total_cost_eur
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:settlement_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations.Reserves:appliesTo  ogit.Utilities.Electricity.Operations.Reserves:BalancingServiceProvider ]
        [ ogit.Utilities.Electricity.Operations.Reserves:appliesTo  ogit.Utilities.Electricity:MarketParticipant ]
        [ ogit.Utilities.Electricity.Operations.Reserves:inControlArea  ogit.Utilities.Electricity:ControlArea ]
    );
.
