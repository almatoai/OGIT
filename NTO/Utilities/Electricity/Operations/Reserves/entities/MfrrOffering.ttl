@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix ogit.Utilities.Electricity.Operations.Reserves: <http://www.purl.org/ogit/Utilities/Electricity/Operations/Reserves/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.Reserves:MfrrOffering
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "MfrrOffering";
    dcterms:description "NC EB Article 34. mFRR (manual Frequency Restoration Reserve) capacity-and-energy bid. Adds activation_time_min (typical 12.5 min).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:offering_id
        ogit.Utilities.Electricity.Operations.Reserves:reserve_unit_ref
        ogit.Utilities.Emissions:period_start
        ogit.Utilities.Emissions:period_end
        ogit.Utilities.Electricity.Market:direction
        ogit.Utilities.Electricity.Operations.Reserves:capacity_mw
        ogit.Utilities.Electricity.Operations.Reserves:capacity_price_eur_per_mw
        ogit.Utilities.Electricity.Operations.Reserves:energy_price_eur_per_mwh
        ogit.Utilities.Electricity.Operations.Reserves:activation_time_min
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:awarded_capacity_mw
        ogit.Utilities.Electricity.Operations.Reserves:awarded_status
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:offering_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations.Reserves:offeredFor  ogit.Utilities.Electricity.Operations.Reserves:ReserveUnit ]
        [ ogit.Utilities.Electricity.Operations.Reserves:clearedIn  ogit.Utilities.Electricity.Market:Market ]
    );
.
