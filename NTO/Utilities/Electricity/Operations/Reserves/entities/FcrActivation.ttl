@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Operations.Reserves: <http://www.purl.org/ogit/Utilities/Electricity/Operations/Reserves/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.Reserves:FcrActivation
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "FcrActivation";
    dcterms:description "Time-resolved FCR delivery anchored on a ReserveUnit. Granularity typical 1 s. Anchor + sgo:Timeseries.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:activationId
        ogit.Utilities.Electricity.Operations.Reserves:reserveUnitRef
        ogit.Utilities:granularitySeconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:activationSource
        ogit.Utilities.Electricity.Operations.Reserves:setpointUnit
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:activationId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations.Reserves:deliveredBy  ogit.Utilities.Electricity.Operations.Reserves:ReserveUnit ]
        [ ogit:generates  ogit:Timeseries ]
    );
.
