@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix ogit.Utilities.Electricity.Operations.Reserves: <http://www.purl.org/ogit/Utilities/Electricity/Operations/Reserves/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.Reserves:RrOffering
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "RrOffering";
    dcterms:description "NC EB Article 35. RR (Replacement Reserve) bid. Adds activation_time_min (typical 30 min) and min_delivery_duration_min (typical 15 min sustained).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:offeringId
        ogit.Utilities.Electricity.Operations.Reserves:reserveUnitRef
        ogit.Utilities:periodStart
        ogit.Utilities:periodEnd
        ogit.Utilities.Electricity.Market:direction
        ogit.Utilities.Electricity.Operations.Reserves:capacityMw
        ogit.Utilities.Electricity.Operations.Reserves:capacityPriceEurPerMw
        ogit.Utilities.Electricity.Operations.Reserves:energyPriceEurPerMwh
        ogit.Utilities.Electricity.Operations.Reserves:activationTimeMin
        ogit.Utilities.Electricity.Operations.Reserves:minDeliveryDurationMin
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:awardedCapacityMw
        ogit.Utilities.Electricity.Operations.Reserves:awardedStatus
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations.Reserves:offeringId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations.Reserves:offeredFor  ogit.Utilities.Electricity.Operations.Reserves:ReserveUnit ]
        [ ogit.Utilities.Electricity.Operations.Reserves:clearedIn  ogit.Utilities.Electricity.Market:Market ]
    );
.
