ogit.Utilities.Electricity.Operations:actsOn
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "actsOn";
    dcterms:description "Asserts that a SwitchAction acts on the target equipment (Switch, PowerTransformer, TapChanger). Cardinality: many2one.";
