@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Operations.StateEstimation:at
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "at";
    dcterms:description "Locates a state-variable anchor at the underlying topology / equipment vertex (e.g. SvVoltage at TopologicalNode, SvPowerFlow at Terminal, SvTapStep at TapChanger). Distinct from `Utilities.Electricity.Grid:at` (TopologicalNode at Substation) -- separate verbs by sub-namespace because the semantics and ranges differ. Cardinality: many2one.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
.
