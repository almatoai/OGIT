@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations.StateEstimation: <http://www.purl.org/ogit/Utilities/Electricity/Operations/StateEstimation/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.StateEstimation:AccumulatorValue
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "AccumulatorValue";
    dcterms:description "CIM cim:AccumulatorValue. Cumulative-counter anchor (energy meter, operation count).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Operations.StateEstimation:parentMeasurementRef
        ogit.Utilities.Electricity.Operations.StateEstimation:unitSymbol
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.StateEstimation:rolloverValue
        ogit.Utilities.Electricity.Operations.StateEstimation:lastResetAt
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations.StateEstimation:belongsTo  ogit.Utilities.Electricity.Operations.StateEstimation:Measurement ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
