@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Operations.StateEstimation: <http://www.purl.org/ogit/Utilities/Electricity/Operations/StateEstimation/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations.StateEstimation:SvVoltage
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "SvVoltage";
    dcterms:description "CIM cim:SvVoltage. SV-profile bus-voltage estimate (magnitude and angle) attached to a TopologicalNode. Anchor + sgo:Timeseries (two channels: magnitude and angle).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Operations.StateEstimation:topological_node_ref
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations.StateEstimation:voltage_v_unit_kv
        ogit.Utilities.Electricity.Operations.StateEstimation:angle_unit_degrees
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations.StateEstimation:at  ogit.Utilities.Electricity.Grid:TopologicalNode ]
        [ ogit.Utilities.Electricity.Operations.StateEstimation:generates  sgo:Timeseries ]
    );
.
