ogit.Utilities.Electricity.Operations.StateEstimation:sensor_accuracy_class
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "sensor_accuracy_class";
    dcterms:description "Accuracy class of the sensor per IEC 61869-1 (e.g. 0.1, 0.2, 0.5, 1.0, 3.0).";
