@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Operations.StateEstimation: <http://www.purl.org/ogit/Utilities/Electricity/Operations/StateEstimation/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Operations.StateEstimation:unitMultiplier
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "unitMultiplier";
    dcterms:description "Unit multiplier per CIM UnitMultiplier enumeration (IEC 61970-301): y (yocto), z (zepto), a (atto), f (femto), p (pico), n (nano), micro, m (milli), c (centi), d (deci), none, da (deca), h (hecto), k (kilo), M (mega), G (giga), T (tera), P (peta), E (exa), Z (zetta), Y (yotta).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "y,z,a,f,p,n,micro,m,c,d,none,da,h,k,M,G,T,P,E,Z,Y";
.
