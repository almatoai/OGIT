@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Operations.StateEstimation: <http://www.purl.org/ogit/Utilities/Electricity/Operations/StateEstimation/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Operations.StateEstimation:unitSymbol
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "unitSymbol";
    dcterms:description "Unit symbol per CIM UnitSymbol enumeration (IEC 61970-301). Common values include V, A, W, var, VA, Hz, K, degC, J, Wh, kWh, Ohm, S, F, H, Wb, T, Pa, rad, deg, m, m2, m3, s, min, h, percent, none, kg, g, t, tonne, l, lPerS, rev, rpm, mol, bar, VArh, WPerA, pu, etc. The CIM UnitSymbol enum is a moving target with each CIM revision -- the attribute is left open per Section 11.1a Regel 3.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
.
