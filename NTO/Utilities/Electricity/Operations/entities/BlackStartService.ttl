@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:BlackStartService
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "BlackStartService";
    dcterms:description "NC ER Article 4. Capability declared by a generator to start without grid supply.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:serviceId
        ogit.Utilities.Electricity.Operations:generatingUnitRef
        ogit.Utilities.Electricity.Operations:serviceClass
        ogit.Utilities.Electricity.Operations:procurementKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:verifiedDate
        ogit.Utilities.Electricity.Operations:nextTestDate
        ogit.Utilities.Electricity.Operations:procurementContractRef
        ogit.Utilities.Electricity.Operations:compensationTerms
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:serviceId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations:providedBy  ogit.Utilities.Electricity:GeneratingUnit ]
        [ ogit:isPartOf  ogit.Utilities.Electricity.Operations:RestorationPlan ]
    );
.
