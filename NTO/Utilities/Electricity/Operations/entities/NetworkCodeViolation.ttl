@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:NetworkCodeViolation
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "NetworkCodeViolation";
    dcterms:description "NC SO. Recorded breach of a defined operational threshold.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:violationId
        ogit.Utilities.Electricity.Operations:codeReference
        ogit.Utilities:subjectRef
        ogit.Utilities.Electricity.Operations:occurredAt
        ogit.Utilities.Electricity.Operations:resolvedAt
    );
    ogit:optional-attributes (
        ogit:severity
        ogit.Utilities.Electricity.Operations:notificationStatus
        ogit.Utilities.Electricity.Operations:reportedToRef
        ogit.Utilities.Electricity.Operations:rootCause
        ogit.Utilities.Electricity.Operations:correctiveActionRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:violationId
    );
    ogit:allowed (
        [ ogit:affects  ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities:reportedBy  ogit.Utilities:NetworkOperator ]
    );
.
