@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:TimeError
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "TimeError";
    dcterms:description "UCTE OH P1. Cumulated phase-deviation in seconds versus a reference clock for one SynchronousArea.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:timeErrorId
        ogit.Utilities.Electricity:synchronousAreaRef
        ogit.Utilities.Electricity.Operations:timeErrorUnit
        ogit.Utilities:granularitySeconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:correctionProgramActive
        ogit.Utilities.Electricity.Operations:correctionTargetSeconds
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:timeErrorId
    );
    ogit:allowed (
        [ ogit.Utilities:measuredFor  ogit.Utilities.Electricity:SynchronousArea ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
