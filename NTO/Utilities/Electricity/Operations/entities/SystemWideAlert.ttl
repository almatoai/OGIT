@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:SystemWideAlert
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "SystemWideAlert";
    dcterms:description "NC SO operational communications. Emergency, contingency notice, market information, restoration alerts issued by control centres.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:alert_id
        ogit.Utilities.Electricity.Operations:alert_kind
        ogit.Utilities.Electricity.Operations:issued_at
        ogit.Utilities.Electricity.Operations:issued_by_ref
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:cleared_at
        ogit.Utilities.Electricity.Operations:affected_area_refs
        ogit.Utilities.Electricity.Operations:message_text
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:alert_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations:issuedBy  ogit.Utilities:NetworkOperator ]
        [ ogit.Utilities.Electricity.Operations:affects  ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities.Electricity.Operations:affects  ogit.Utilities.Electricity:SynchronousArea ]
    );
.
