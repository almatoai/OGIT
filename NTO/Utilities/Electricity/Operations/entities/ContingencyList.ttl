@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:ContingencyList
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ContingencyList";
    dcterms:description "CIM cim:ContingencyList. Named collection of Contingencies evaluated together in a ContingencyAnalysis.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:list_id
        ogit:name
        ogit.Utilities:subject_ref
        ogit.Utilities:valid_from
    );
    ogit:optional-attributes (
        ogit.Utilities:valid_until
        ogit.Utilities.Electricity.Grid:member_count
        ogit.Utilities.Electricity.Operations:analysis_priority
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:list_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations:consistsOf  ogit.Utilities.Electricity.Operations:Contingency ]
        [ ogit.Utilities.Electricity.Operations:analyzedBy  ogit.Utilities.Electricity.Operations:ContingencyAnalysis ]
    );
.
