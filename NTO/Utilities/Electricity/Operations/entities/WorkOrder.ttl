@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:WorkOrder
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "WorkOrder";
    dcterms:description "Cross-domain maintenance / repair work order on equipment. Holds the work kind, scheduling window, the assigned team, and the cost rollup. The work subject is expressed via the `Utilities:appliesTo -> PowerSystemResource` graph edge (typed verb, see allowed edges); no parallel `subjectRef` attribute is declared (per QS Round 14 Sonnet IMPL-10 -- verb is canonical for structural relations).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:workOrderId
        ogit.Utilities.Electricity.Operations:workKind
        ogit:status
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:scheduledStart
        ogit.Utilities.Electricity.Operations:scheduledEnd
        ogit.Utilities.Electricity.Operations:actualStart
        ogit.Utilities.Electricity.Operations:actualEnd
        ogit.Utilities.Electricity.Operations:assignedTeamRef
        ogit.Utilities.Electricity.Operations:partsUsedPayload
        ogit.Utilities.Electricity.Operations:totalCost
        ogit:priority
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:workOrderId
    );
    ogit:allowed (
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity:PowerSystemResource ]
        [ ogit:causes  ogit.Utilities.Electricity.Operations:PlannedOutage ]
        [ ogit:causes  ogit.Utilities:Outage ]
    );
.
