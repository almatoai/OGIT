@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:Contingency
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "Contingency";
    dcterms:description "CIM cim:Contingency. A defined hypothetical event used in N-1 / N-k security analysis.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:contingencyId
        ogit:name
        ogit.Utilities.Electricity.Operations:contingencyKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:frequencyClass
        ogit.Utilities.Electricity.Operations:severityRank
        ogit.Utilities.Electricity.Operations:mustStudy
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:contingencyId
    );
    ogit:allowed (
        [ ogit:affects  ogit.Utilities.Electricity:GeneratingUnit ]
        [ ogit:affects  ogit.Utilities.Electricity.Grid:ACLineSegment ]
        [ ogit.Utilities.Electricity.Operations:analyzedIn  ogit.Utilities.Electricity.Operations:ContingencyAnalysis ]
        [ ogit:isPartOf  ogit.Utilities.Electricity.Operations:ContingencyList ]
    );
.
