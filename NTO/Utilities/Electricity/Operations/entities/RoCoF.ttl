@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:RoCoF
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "RoCoF";
    dcterms:description "UCTE OH P1, NC RfG. Rate of change of frequency in Hz/s. Anchor + sgo:Timeseries with computation window typically 500 ms.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:rocof_id
        ogit.Utilities:subject_ref
        ogit.Utilities.Electricity.Operations:rocof_unit
        ogit.Utilities.Electricity.Operations:window_ms
        ogit.Utilities:granularity_seconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:computation_method
        ogit.Utilities.Electricity.Operations:threshold_alert_hz_per_s
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:rocof_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations:measuredFor  ogit.Utilities.Electricity:SynchronousArea ]
        [ ogit.Utilities.Electricity.Operations:measuredFor  ogit.Utilities.Electricity:GeneratingUnit ]
        [ ogit.Utilities.Electricity.Operations:generates  sgo:Timeseries ]
    );
.
