@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:ForcedOutage
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities:Outage;
    rdfs:label "ForcedOutage";
    dcterms:description "Unplanned-outage variant from fault. Adds fault classification, location, duration, auto-reclose attempts, and the protection-action reference.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:outageId
        ogit.Utilities:outageKind
        ogit.Utilities:startTime
        ogit.Utilities:domain
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:faultKind
        ogit.Utilities.Electricity.Operations:faultLocation
        ogit.Utilities.Electricity.Operations:faultDurationMs
        ogit.Utilities.Electricity.Operations:autoRecloseAttempts
        ogit.Utilities.Electricity.Operations:successfulReclose
        ogit.Utilities.Electricity.Operations:protectionActionRef
        ogit.Utilities:endTime
        ogit.Utilities:expectedDuration
        ogit.Utilities:cause
        ogit.Utilities:affectedPopulation
        ogit.Utilities:recoveryActionRef
        ogit:severity
        ogit.Utilities:criticalityLevel
        ogit.Utilities:restorationPriority
    );
    ogit:indexed-attributes (
        ogit.Utilities:outageId
        ogit.Utilities:outageId
    );
    ogit:allowed (
        [ ogit:affects  ogit.Utilities.Electricity:PowerSystemResource ]
        [ ogit.Utilities:causedBy  ogit.Utilities.Electricity.Grid:ACLineSegment ]
        [ ogit.Utilities:causedBy  ogit.Utilities.Electricity:PowerSystemResource ]
        [ ogit.Utilities:reportedBy  ogit.Utilities:NetworkOperator ]
    );
.
