@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:ForcedOutage
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities:Outage;
    rdfs:label "ForcedOutage";
    dcterms:description "Unplanned-outage variant from fault. Adds fault classification, location, duration, auto-reclose attempts, and the protection-action reference.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:outage_id
        ogit.Utilities:outage_kind
        ogit.Utilities:start_time
        ogit.Utilities:domain
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:fault_kind
        ogit.Utilities.Electricity.Operations:fault_location
        ogit.Utilities.Electricity.Operations:fault_duration_ms
        ogit.Utilities.Electricity.Operations:auto_reclose_attempts
        ogit.Utilities.Electricity.Operations:successful_reclose
        ogit.Utilities.Electricity.Operations:protection_action_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities:outage_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations:affects  ogit.Utilities.Electricity:PowerSystemResource ]
        [ ogit.Utilities.Electricity.Operations:causedBy  ogit.Utilities.Electricity.Grid:ACLineSegment ]
    );
.
