@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:SystemFrequency
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "SystemFrequency";
    dcterms:description "UCTE OH P1, NC SO Article 127. System frequency of the synchronous area. Anchor + sgo:Timeseries.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:frequencyId
        ogit.Utilities.Electricity:synchronousAreaRef
        ogit.Utilities.Electricity.Operations:freqUnit
        ogit.Utilities.Electricity.Operations:nominalFreqHz
        ogit.Utilities:granularitySeconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Emissions:measurementMethod
        ogit.Utilities.Electricity.Operations:measurementLocationRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:frequencyId
    );
    ogit:allowed (
        [ ogit.Utilities:measuredFor  ogit.Utilities.Electricity:SynchronousArea ]
        [ ogit:generates  ogit:Timeseries ]
    );
.
