@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:ContingencyAnalysis
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ContingencyAnalysis";
    dcterms:description "NC SO Article 33. The N-1 (or N-k) security study run on a snapshot. The pass/fail counts, risk metrics, and result summary live on a sgo:Timeseries attached via generates, not as a JSON payload on this vertex (Section 7a).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:analysisId
        ogit.Utilities:subjectRef
        ogit.Utilities.Electricity.Operations:snapshotTime
        ogit.Utilities.Electricity.Operations:analysisKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:toolName
        ogit.Utilities.Electricity:toolVersion
        ogit.Utilities.Electricity.Operations:computeDurationS
        ogit.Utilities.Electricity.Operations:triggeredByKind
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:analysisId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations:analyzes  ogit.Utilities.Electricity.Operations:ContingencyList ]
        [ ogit.Utilities.Electricity.Operations:producedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
