@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:CongestionManagementAction
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "CongestionManagementAction";
    dcterms:description "NC CACM, NC SO. Remedial action against congestion (re-dispatch, counter-trading, topological change, curtailment, load-shed).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:action_id
        ogit.Utilities.Electricity.Operations:congestion_subject_ref
        ogit.Utilities.Electricity.Operations:action_kind
        ogit.Utilities.Electricity.Operations:volume_mw
        ogit.Utilities.Electricity.Operations:effective_period_start
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:effective_period_end
        ogit.Utilities.Electricity.Operations:cost
        ogit.Utilities.Electricity.Operations:triggered_by_kind
        ogit.Utilities.Electricity.Operations:affected_market_participants_refs
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:action_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations:targets  ogit.Utilities.Electricity.Grid:ACLineSegment ]
        [ ogit.Utilities.Electricity.Operations:targets  ogit.Utilities.Electricity:Interconnector ]
        [ ogit.Utilities.Electricity.Operations:affects  ogit.Utilities.Electricity:GeneratingUnit ]
    );
.
