@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:CongestionManagementAction
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "CongestionManagementAction";
    dcterms:description "NC CACM, NC SO. Remedial action against congestion (re-dispatch, counter-trading, topological change, curtailment, load-shed).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:actionId
        ogit.Utilities.Electricity.Operations:congestionSubjectRef
        ogit.Utilities.Electricity.Operations:actionKind
        ogit.Utilities.Electricity.Operations:volumeMw
        ogit.Utilities.Electricity.Operations:effectivePeriodStart
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:effectivePeriodEnd
        ogit.Utilities.Electricity.Operations:cost
        ogit.Utilities.Electricity.Operations:triggeredByKind
        ogit.Utilities.Electricity.Operations:affectedMarketParticipantsRefs
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:actionId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Operations:targets  ogit.Utilities.Electricity.Grid:ACLineSegment ]
        [ ogit.Utilities.Electricity.Operations:targets  ogit.Utilities.Electricity:Interconnector ]
        [ ogit:affects  ogit.Utilities.Electricity:GeneratingUnit ]
    );
.
