@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Operations:AreaControlError
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "AreaControlError";
    dcterms:description "UCTE OH P1, NC SO Article 142. Real-time signed signal of one control area in MW. Anchor + sgo:Timeseries: the vertex carries metadata, the ACE signal over time rides on the linked sgo:Timeseries.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Operations:aceId
        ogit.Utilities.Electricity:controlAreaRef
        ogit.Utilities.Electricity.Operations:aceUnit
        ogit.Utilities:granularitySeconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Operations:computationMethod
        ogit.Utilities.Electricity.Operations:kFactorMwPerHz
        ogit.Utilities.Electricity.Operations:biasSetting
        ogit.Utilities.Electricity:lfcBlockRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Operations:aceId
    );
    ogit:allowed (
        [ ogit.Utilities:measuredFor  ogit.Utilities.Electricity:ControlArea ]
        [ ogit:generates  ogit:Timeseries ]
    );
.
