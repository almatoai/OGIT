@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Operations:computationMethod
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "computationMethod";
    dcterms:description "ACE / RoCoF computation method: open_loop, closed_loop_with_K_factor, closed_loop_with_frequency_bias, point_to_point, sliding_window.";
