@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Operations:     <http://www.purl.org/ogit/Utilities/Electricity/Operations/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Operations:faultKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "faultKind";
    dcterms:description "Fault classification per IEC 60909 (NTO domain-autonomous phase-based nomenclature, semantically equivalent but not byte-identical to CIM FaultKind which uses line-based labels lineToGround / lineToLine / lineToLineToGround / threePhase / threePhaseToGround): single_phase_to_ground, two_phase, two_phase_to_ground, three_phase (balanced three-phase clear), three_phase_to_ground (three-phase-to-earth). The MappingRule DSL converts to / from CIM line-based labels when interoperating with CGMES instance data.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "single_phase_to_ground,two_phase,two_phase_to_ground,three_phase,three_phase_to_ground";
.
