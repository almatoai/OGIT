ogit.Utilities.Electricity.Operations:mustStudy
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "mustStudy";
    dcterms:description "Boolean. True if the contingency must be included in every N-1 study (e.g. regulatory must-run).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
