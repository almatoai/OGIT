@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:coolingWaterSource
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "coolingWaterSource";
    dcterms:description "Water source for cooling: river name, lake name, sea name, or 'dry' for dry-cooling units.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
