@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:foundationType
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "foundationType";
    dcterms:description "Foundation technology of an offshore turbine: monopile, jacket, gravity_base, suction_bucket, floating_spar, floating_semisubmersible, floating_tlp.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "monopile,jacket,gravity_base,suction_bucket,floating_spar,floating_semisubmersible,floating_tlp";
.
