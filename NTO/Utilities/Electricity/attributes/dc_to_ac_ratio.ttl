@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:dc_to_ac_ratio
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "dc_to_ac_ratio";
    dcterms:description "Ratio of installed DC capacity to AC inverter capacity (typically 1.1 - 1.4 for utility-scale PV).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
