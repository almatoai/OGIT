@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:hydroKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "hydroKind";
    dcterms:description "Hydro technology per CIM HydroPlantStorageKind plus ENTSO-E TP marine extensions: runOfRiver, reservoir, pumpedStorage, tide, pondage (CIM day-balancing pondage between run-of-river and full reservoir), wave (non-CIM ENTSO-E TP marine subcategory). Casing follows CIM upstream camelCase per Section 11.1a Regel 5.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "runOfRiver,reservoir,pumpedStorage,tide,pondage,wave";
.
