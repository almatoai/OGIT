@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:memberCountryIso2List
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "memberCountryIso2List";
    dcterms:description "Comma-separated list of ISO-3166 alpha-2 codes for the countries fully or partially inside the area.";
