@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:shareFraction
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "shareFraction";
    dcterms:description "Ownership fraction as a number in [0.0, 1.0]. The sum of share_fraction over all active OwnershipShare anchors pointing at the same asset SHOULD equal 1.0; this cross-vertex invariant is enforced by the Connector-Framework MappingRule validator V13a, not by OGIT-Validator.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
