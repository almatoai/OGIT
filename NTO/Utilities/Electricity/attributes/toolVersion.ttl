ogit.Utilities.Electricity:toolVersion
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "toolVersion";
    dcterms:description "Version string of the analysis or simulation tool. Used by Operations:ContingencyAnalysis and Dynamics:DynamicSimulationCase; lives in Electricity as the lowest common ancestor.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
