@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:roleKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "roleKind";
    dcterms:description "Market role classification: producer, supplier, trader, balancing_responsible_party (BRP -- responsibility for imbalance settlement), retailer, aggregator, market_operator, transmission_system_operator, distribution_system_operator, nominated_electricity_market_operator, flexibility_service_provider, metering_responsible, resource_provider, balance_service_provider (BSP -- delivers balancing energy/capacity per ENTSO-E EB GL Article 2, distinct from BRP).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "producer,supplier,trader,balancing_responsible_party,retailer,aggregator,market_operator,transmission_system_operator,distribution_system_operator,nominated_electricity_market_operator,flexibility_service_provider,metering_responsible,resource_provider,balance_service_provider";
.
