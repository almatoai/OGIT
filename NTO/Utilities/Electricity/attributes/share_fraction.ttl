@prefix ogit:                          <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:    <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                           <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                       <http://purl.org/dc/terms/> .

ogit.Utilities.Electricity:share_fraction
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "share_fraction";
    dcterms:description "Ownership fraction expressed as a number in [0.0, 1.0]. The sum of all share_fraction values across active OwnershipShare vertices pointing to the same physical asset SHOULD equal 1.0; this cross-vertex invariant is enforced by the Connector-Framework MappingRule validator (V13a), not by OGIT-Validator. Used by reified OwnershipShare.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
.
