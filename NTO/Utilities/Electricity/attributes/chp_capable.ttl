ogit.Utilities.Electricity:chp_capable
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "chp_capable";
    dcterms:description "Boolean. True if the unit can also export usable thermal energy (combined heat and power).";
