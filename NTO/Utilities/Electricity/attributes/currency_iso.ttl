@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:currency_iso
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "currency_iso";
    dcterms:description "ISO 4217 currency code used by the bidding zone (EUR, GBP, CHF, NOK).";
