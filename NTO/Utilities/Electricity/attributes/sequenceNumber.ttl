@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity:sequenceNumber
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "sequenceNumber";
    dcterms:description "Ordinal sequence number on a parent object. Used by Grid:Terminal (CIM Terminal.sequenceNumber on parent equipment), Diagram:DiagramObjectPoint and Diagram:PositionPoint (point order in the polyline), Operations:SwitchAction (step order inside a SwitchingPlan). Lives in Utilities.Electricity as the lowest common ancestor of these three sub-namespaces.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
