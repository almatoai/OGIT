ogit.Utilities.Electricity.Grid:tculControlMode
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "tculControlMode";
    dcterms:description "On-load tap-changer control mode per CIM RegulatingControlModeKind: voltage, reactivePower, activePower, timeScheduled.";
