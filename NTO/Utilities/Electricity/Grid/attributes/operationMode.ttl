ogit.Utilities.Electricity.Grid:operationMode
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "operationMode";
    dcterms:description "HVDC operation mode: rectifier, inverter, bidirectional.";
