@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Grid:isInfiniteDuration
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "isInfiniteDuration";
    dcterms:description "Boolean. True if the limit is permanent (acceptable_duration_seconds is null or treated as unbounded).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "true,false";
.
