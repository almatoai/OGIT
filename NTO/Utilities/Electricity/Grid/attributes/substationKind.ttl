@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Grid:substationKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "substationKind";
    dcterms:description "Substation classification: transmission, distribution, switching, converter, customer, mobile (NTO additions for service substations and mobile units), islandIsolating, industrialFacility, generationStation. CIM SubstationKind core (transmission / distribution / switching / converter / industrialFacility / islandIsolating) is included; customer, mobile and generationStation are NTO-domain-autonomous extensions.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "transmission,distribution,switching,converter,customer,mobile,islandIsolating,industrialFacility,generationStation";
.
