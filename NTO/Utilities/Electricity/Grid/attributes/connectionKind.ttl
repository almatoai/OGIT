@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Grid:connectionKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "connectionKind";
    dcterms:description "Transformer end connection kind per CIM 17 / CGMES 3.0 WindingConnection: Y, D, Z, Yn, Zn, A (auto-transformer), I (independent winding), G (Zigzag-Grounding per CGMES 3.0 Boundary-Profile WindingConnection extension; anchor `frozen_at: CGMES3.0`). Delta windings have no neutral point and therefore no `Dn` form.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "Y,D,Z,Yn,Zn,A,I,G";
.
