@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Grid:limitTypeKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "limitTypeKind";
    dcterms:description "CIM cim:OperationalLimitType.kind enum: patl (permanent admissible transmission loading), tatl (temporary admissible transmission loading), dynamic (state-dependent), static (fixed), warning, lowVoltage, highVoltage, lowVoltageEmergency, highVoltageEmergency, lowVoltageDisturbance, highVoltageDisturbance, current. The voltage-related values follow CIM camelCase per Section 11.1a Regel 5.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "patl,tatl,dynamic,static,warning,lowVoltage,highVoltage,lowVoltageEmergency,highVoltageEmergency,lowVoltageDisturbance,highVoltageDisturbance,current";
.
