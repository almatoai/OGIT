@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:ACLineSegment
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "ACLineSegment";
    dcterms:description "CIM cim:ACLineSegment. One section of an alternating-current overhead line or cable. Holds the per-section R/X/B/G impedance parameters plus geometry and rated current.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:rOhm
        ogit.Utilities.Electricity.Grid:xOhm
        ogit.Utilities.Electricity.Grid:lengthKm
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:bSiemens
        ogit.Utilities.Electricity.Grid:gSiemens
        ogit.Utilities.Electricity.Grid:r0Ohm
        ogit.Utilities.Electricity.Grid:x0Ohm
        ogit.Utilities.Electricity.Grid:b0Siemens
        ogit.Utilities.Electricity.Grid:g0Siemens
        ogit.Utilities.Electricity.Grid:bchSiemens
        ogit.Utilities.Electricity.Grid:gchSiemens
        ogit.Utilities.Electricity.Grid:shuntRatio
        ogit.Utilities.Electricity.Grid:ratedCurrentA
        ogit.Utilities.Electricity.Grid:conductorMaterial
        ogit.Utilities.Electricity.Grid:circuitArrangement
        ogit.Utilities.Electricity.Grid:towerType
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity:aliasName
        ogit.Utilities.Electricity:categoryRef
        ogit.Utilities:commissioningDate
        ogit.Utilities:decommissioningDate
        ogit.Utilities.Electricity:psrType
        ogit.Utilities.Electricity:externalRefs
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:hasTerminal  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:Interconnector ]
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
    );
.
