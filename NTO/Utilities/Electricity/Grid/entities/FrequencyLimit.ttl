@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:FrequencyLimit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities:OperationalLimit;
    rdfs:label "FrequencyLimit";
    dcterms:description "ENTSO-E NC SO frequency limit. Typed limit on system frequency.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:limit_id
        ogit.Utilities:limit_kind
        ogit.Utilities:limit_value
        ogit.Utilities:limit_unit
        ogit.Utilities:limit_direction
        ogit.Utilities.Electricity.Grid:value_hz
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:acceptable_duration_seconds
        ogit.Utilities.Electricity.Grid:direction_kind
    );
    ogit:indexed-attributes (
        ogit.Utilities:limit_id
    );
    ogit:allowed (

    );
.
