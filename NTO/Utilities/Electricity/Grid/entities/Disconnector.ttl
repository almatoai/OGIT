@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:Disconnector
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Grid:Switch;
    rdfs:label "Disconnector";
    dcterms:description "CIM cim:Disconnector. Switch without load-break capability (isolation under no-current condition).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:normalOpen
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:ratedCurrentA
        ogit.Utilities.Electricity.Grid:breakingCapacityKa
        ogit.Utilities.Electricity.Grid:makeCapacityKa
        ogit.Utilities.Electricity.Grid:switchOnCount
        ogit.Utilities:commissioningYear
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity:aliasName
        ogit.Utilities.Electricity:categoryRef
        ogit.Utilities:commissioningDate
        ogit.Utilities:decommissioningDate
        ogit.Utilities.Electricity:psrType
        ogit.Utilities.Electricity:externalRefs
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:hasTerminal  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit:isPartOf  ogit.Utilities.Electricity.Grid:Bay ]
        [ ogit:isPartOf  ogit.Utilities.Electricity.Grid:Substation ]
        [ ogit:generates  sgo:Timeseries ]
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
    );
.
