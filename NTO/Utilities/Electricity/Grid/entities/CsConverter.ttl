@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:CsConverter
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "CsConverter";
    dcterms:description "CIM cim:CsConverter. Current-source HVDC converter (LCC, classic thyristor).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:max_alpha_degrees
        ogit.Utilities.Electricity.Grid:max_gamma_degrees
        ogit.Utilities.Electricity.Grid:pole_loss_p_mw
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:rated_idc_a
        ogit.Utilities.Electricity.Grid:rated_udc_kv
        ogit.Utilities.Electricity.Grid:min_alpha_degrees
        ogit.Utilities.Electricity.Grid:min_gamma_degrees
        ogit.Utilities.Electricity.Grid:commutation_capability
        ogit.Utilities.Electricity.Grid:idle_loss_p_mw
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:hasTerminal  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit.Utilities.Electricity.Grid:partOf  ogit.Utilities.Electricity.Grid:DCConverterUnit ]
        [ ogit.Utilities.Electricity.Grid:generates  sgo:Timeseries ]
    );
.
