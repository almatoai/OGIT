@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:TopologicalIsland
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "TopologicalIsland";
    dcterms:description "CIM cim:TopologicalIsland. Set of TopologicalNodes connected through closed switches; per AC island one entry.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:angleRefTopologicalNodeRef
        ogit.Utilities.Electricity:synchronousAreaRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:consistsOf  ogit.Utilities.Electricity.Grid:TopologicalNode ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:SynchronousArea ]
    );
.
