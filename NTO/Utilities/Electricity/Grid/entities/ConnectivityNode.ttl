@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:ConnectivityNode
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "ConnectivityNode";
    dcterms:description "CIM cim:ConnectivityNode. EQ-profile electrical connection point. Multiple terminals attach here.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:parent_container_ref
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:boundary_point
        ogit.Utilities.Electricity.Grid:fromendiso_code
        ogit.Utilities.Electricity.Grid:toendiso_code
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:connects  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit.Utilities.Electricity.Grid:partOf  ogit.Utilities.Electricity.Grid:VoltageLevel ]
        [ ogit.Utilities.Electricity.Grid:partOf  ogit.Utilities.Electricity.Grid:Bay ]
        [ ogit.Utilities.Electricity.Grid:groupedInto  ogit.Utilities.Electricity.Grid:TopologicalNode ]
    );
.
