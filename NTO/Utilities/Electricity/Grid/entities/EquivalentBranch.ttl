@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:EquivalentBranch
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "EquivalentBranch";
    dcterms:description "CIM cim:EquivalentBranch. Boundary-model equivalent representing an external branch impedance.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:r_ohm
        ogit.Utilities.Electricity.Grid:x_ohm
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:r0_ohm
        ogit.Utilities.Electricity.Grid:x0_ohm
        ogit.Utilities.Electricity.Grid:r21_ohm
        ogit.Utilities.Electricity.Grid:x21_ohm
        ogit.Utilities.Electricity.Grid:rated_current_a
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:hasTerminal  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit.Utilities.Electricity.Grid:representsExternal  ogit.Utilities.Electricity:ControlArea ]
    );
.
