@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:BoundaryPoint
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "BoundaryPoint";
    dcterms:description "ENTSO-E CGMES Boundary Set extension. Marks a ConnectivityNode as a CGMES boundary point used for cross-TSO topology assembly.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:connectivityNodeRef
        ogit.Utilities.Electricity.Grid:fromEndpointIsoCode
        ogit.Utilities.Electricity.Grid:toEndpointIsoCode
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:boundaryDescription
        ogit.Utilities.Electricity.Grid:tielineId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:marks  ogit.Utilities.Electricity.Grid:ConnectivityNode ]
    );
.
