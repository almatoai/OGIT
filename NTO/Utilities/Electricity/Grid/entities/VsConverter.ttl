@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:VsConverter
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "VsConverter";
    dcterms:description "CIM cim:VsConverter. Voltage-source HVDC converter (VSC, IGBT-based).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:ratedUdcKv
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:qSetPwmMinMvar
        ogit.Utilities.Electricity.Grid:qSetPwmMaxMvar
        ogit.Utilities.Electricity.Grid:deltaMaxDegrees
        ogit.Utilities.Electricity.Grid:pqCapabilityCurveRef
        ogit.Utilities.Electricity.Grid:poleLossPMw
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:hasTerminal  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit:isPartOf  ogit.Utilities.Electricity.Grid:DCConverterUnit ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
