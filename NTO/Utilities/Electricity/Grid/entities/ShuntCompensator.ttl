@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:ShuntCompensator
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "ShuntCompensator";
    dcterms:description "CIM cim:ShuntCompensator. Linear or non-linear shunt reactor / capacitor for reactive-power compensation.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:shuntKind
        ogit.Utilities.Electricity:nominalQMvar
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:nominalVoltageKv
        ogit.Utilities.Electricity.Grid:sectionCount
        ogit.Utilities.Electricity.Grid:normalSections
        ogit.Utilities.Electricity.Grid:bPerSectionSiemens
        ogit.Utilities.Electricity.Grid:gPerSectionSiemens
        ogit.Utilities.Electricity.Grid:voltageSensitivity
        ogit.Utilities.Electricity.Grid:regulatingControlRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:controlledBy  ogit.Utilities.Electricity.Grid:RegulatingControl ]
        [ ogit.Utilities.Electricity.Grid:hasTerminal  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
