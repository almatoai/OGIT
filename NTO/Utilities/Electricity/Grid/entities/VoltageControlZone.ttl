@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:VoltageControlZone
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "VoltageControlZone";
    dcterms:description "CIM cim:VoltageControlZone. CGMES EQ-profile container grouping BusbarSections / VoltageLevels under a shared voltage-regulation regime. Each zone has one designated voltage-setpoint reference busbar; voltage-control commands inside the zone derive from that reference. The applicable setpoint schedule rides on `Operations:VoltageControlSchedule` (Anchor + sgo:Timeseries).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:zoneId
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:nominalVoltageKv
        ogit.Utilities.Electricity.Grid:regulationBasisRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Grid:zoneId
    );
    ogit:allowed (
        [ ogit:consistsOf  ogit.Utilities.Electricity.Grid:BusbarSection ]
        [ ogit:consistsOf  ogit.Utilities.Electricity.Grid:VoltageLevel ]
    );
.
