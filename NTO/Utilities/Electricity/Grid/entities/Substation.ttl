@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:Substation
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Grid:EquipmentContainer;
    rdfs:label "Substation";
    dcterms:description "CIM cim:Substation. Physical installation grouping voltage levels.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities:countryIso2
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:substationKind
        ogit.Utilities.Electricity.Grid:regionRef
        ogit.Utilities.Electricity.Grid:subregionRef
        ogit.Utilities:operatorRef
        ogit.Utilities:commissioningYear
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity.Grid:GeographicalRegion ]
        [ ogit:isPartOf  ogit.Utilities.Electricity.Grid:SubGeographicalRegion ]
        [ ogit:consistsOf  ogit.Utilities.Electricity.Grid:VoltageLevel ]
        [ ogit:consistsOf  ogit.Utilities.Electricity.Grid:Bay ]
    );
.
