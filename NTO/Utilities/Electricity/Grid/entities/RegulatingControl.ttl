@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:RegulatingControl
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "RegulatingControl";
    dcterms:description "CIM cim:RegulatingControl. Generic control reference used by tap changers, shunt compensators, etc.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Grid:controlMode
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:targetValue
        ogit.Utilities.Electricity.Grid:targetValueUnit
        ogit.Utilities.Electricity.Grid:targetDeadband
        ogit.Utilities.Electricity.Grid:enabled
        ogit.Utilities.Electricity.Grid:discrete
        ogit.Utilities.Electricity.Grid:regulatingControlPriority
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:RatioTapChanger ]
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:PhaseTapChanger ]
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:ShuntCompensator ]
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:StaticVarCompensator ]
    );
.
