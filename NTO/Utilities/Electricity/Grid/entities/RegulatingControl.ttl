@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:RegulatingControl
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "RegulatingControl";
    dcterms:description "CIM cim:RegulatingControl. Generic control reference used by tap changers, shunt compensators, etc. Modelled as a PowerSystemResource subtype to match the CIM inheritance (cim:RegulatingControl extends cim:PowerSystemResource). Per QS Round 4 finding CONS-05: targetValue, targetValueUnit, targetDeadband, enabled are CGMES SSH-profile attributes (time-variant); they live exclusively on the linked sgo:Timeseries (channels RegulatingControl.targetValue, .targetDeadband, .enabled), not as vertex attributes. The vertex carries only the static control-mode discriminator plus regulation-priority metadata.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Grid:controlMode
        ogit:name
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:discrete
        ogit.Utilities.Electricity.Grid:regulatingControlPriority
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity:aliasName
        ogit.Utilities.Electricity:categoryRef
        ogit.Utilities:commissioningDate
        ogit.Utilities:decommissioningDate
        ogit.Utilities.Electricity:psrType
        ogit.Utilities.Electricity:externalRefs
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:RatioTapChanger ]
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:PhaseTapChanger ]
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:ShuntCompensator ]
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:StaticVarCompensator ]
        [ ogit:generates  ogit:Timeseries ]
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
    );
.
