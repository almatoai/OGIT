@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:TransformerStarImpedance
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "TransformerStarImpedance";
    dcterms:description "CIM cim:TransformerStarImpedance. Star-equivalent impedance representation for three-winding transformers (per-winding R, X derived from the star equivalent).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Grid:parent_transformer_end_ref
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:r_ohm
        ogit.Utilities.Electricity.Grid:x_ohm
        ogit.Utilities.Electricity.Grid:r0_ohm
        ogit.Utilities.Electricity.Grid:x0_ohm
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:partOf  ogit.Utilities.Electricity.Grid:PowerTransformerEnd ]
    );
.
