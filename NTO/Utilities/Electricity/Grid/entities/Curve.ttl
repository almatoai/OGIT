@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:Curve
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "Curve";
    dcterms:description "CIM cim:Curve. Generic two-axis curve container used by RegulatingControl, ReactiveCapabilityCurve, TapChanger, LoadDynamics, VsConverter capability.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:curveStyle
        ogit.Utilities.Electricity.Grid:xUnit
        ogit.Utilities.Electricity.Grid:y1Unit
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:y2Unit
        ogit.Utilities.Electricity.Grid:y3Unit
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:consistsOf  ogit.Utilities.Electricity.Grid:CurveData ]
    );
.
