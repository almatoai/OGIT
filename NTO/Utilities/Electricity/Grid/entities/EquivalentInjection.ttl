@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:EquivalentInjection
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "EquivalentInjection";
    dcterms:description "CIM cim:EquivalentInjection. Equivalent source/sink representing an external system at a boundary point.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:min_p_mw
        ogit.Utilities.Electricity.Grid:max_p_mw
        ogit.Utilities.Electricity.Grid:min_q_mvar
        ogit.Utilities.Electricity.Grid:max_q_mvar
        ogit.Utilities.Electricity.Grid:r_ohm
        ogit.Utilities.Electricity.Grid:x_ohm
        ogit.Utilities.Electricity.Grid:regulation_capability
        ogit.Utilities.Electricity.Grid:regulation_target_kv
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:hasTerminal  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit.Utilities.Electricity.Grid:representsExternal  ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities.Electricity.Grid:representsExternal  ogit.Utilities.Electricity:SynchronousArea ]
    );
.
