@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:PhaseTapChanger
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "PhaseTapChanger";
    dcterms:description "CIM cim:PhaseTapChanger. Phase-shifting transformer control.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Grid:low_step
        ogit.Utilities.Electricity.Grid:high_step
        ogit.Utilities.Electricity.Grid:neutral_step
        ogit.Utilities.Electricity.Grid:phase_tap_changer_kind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:normal_step
        ogit.Utilities.Electricity.Grid:voltage_step_increment
        ogit.Utilities.Electricity.Grid:phase_angle_increment_degrees
        ogit.Utilities.Electricity.Grid:winding_connection_angle
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:controls  ogit.Utilities.Electricity.Grid:PowerTransformerEnd ]
        [ ogit.Utilities.Electricity.Grid:generates  sgo:Timeseries ]
    );
.
