@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:StaticVarCompensator
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "StaticVarCompensator";
    dcterms:description "CIM cim:StaticVarCompensator. Dynamic reactive-power source using thyristor-controlled reactors and capacitors.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:inductiveRatingMvar
        ogit.Utilities.Electricity.Grid:capacitiveRatingMvar
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:slopePercent
        ogit.Utilities.Electricity.Grid:voltageSetPointKv
        ogit.Utilities.Electricity.Grid:regulatingControlRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:controlledBy  ogit.Utilities.Electricity.Grid:RegulatingControl ]
        [ ogit.Utilities.Electricity.Grid:hasTerminal  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
