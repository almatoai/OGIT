@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:Line
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Grid:EquipmentContainer;
    rdfs:label "Line";
    dcterms:description "CIM cim:Line. Grouping container for one or more ACLineSegments and DCLineSegments forming one physical line corridor.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:region_ref
        ogit.Utilities.Electricity.Grid:voltage_level_ref
        ogit.Utilities:commissioning_year
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:consistsOf  ogit.Utilities.Electricity.Grid:ACLineSegment ]
        [ ogit.Utilities.Electricity.Grid:consistsOf  ogit.Utilities.Electricity.Grid:DCLineSegment ]
        [ ogit.Utilities.Electricity.Grid:partOf  ogit.Utilities.Electricity:Interconnector ]
    );
.
