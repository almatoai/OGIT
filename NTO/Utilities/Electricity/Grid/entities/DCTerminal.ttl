@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:DCTerminal
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "DCTerminal";
    dcterms:description "CIM cim:DCTerminal. DC-side equivalent of Terminal. Connects DC conducting equipment to a DCNode.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity:sequenceNumber
        ogit.Utilities.Electricity.Grid:dcNodeRef
        ogit.Utilities.Electricity.Grid:parentDcConductingEquipmentRef
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:connected
        ogit:name
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:connectsAt  ogit.Utilities.Electricity.Grid:DCNode ]
    );
.
