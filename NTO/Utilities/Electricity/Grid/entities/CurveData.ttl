@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:CurveData
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "CurveData";
    dcterms:description "CIM cim:CurveData. Single (x, y1, [y2, y3]) data point of a parent Curve. The parent Curve is expressed via the `ogit:isPartOf -> Curve` graph edge; no parallel `parentCurveRef` attribute is declared (per QS Round 13 architecture decision -- verb is canonical for graph relations).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Grid:xValue
        ogit.Utilities.Electricity.Grid:y1Value
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:y2Value
        ogit.Utilities.Electricity.Grid:y3Value
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity.Grid:Curve ]
    );
.
