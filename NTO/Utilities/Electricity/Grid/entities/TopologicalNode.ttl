@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:TopologicalNode
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "TopologicalNode";
    dcterms:description "CIM cim:TopologicalNode. TP-profile collapsed-bus representation derived from ConnectivityNode topology after switching state is applied.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:baseVoltageKv
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:parentIslandRef
        ogit.Utilities.Electricity.Grid:boundaryPoint
        ogit.Utilities.Electricity.Grid:equivalentBusId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit:consistsOf  ogit.Utilities.Electricity.Grid:ConnectivityNode ]
        [ ogit:isPartOf  ogit.Utilities.Electricity.Grid:TopologicalIsland ]
        [ ogit.Utilities.Electricity.Grid:at  ogit.Utilities.Electricity.Grid:Substation ]
        [ ogit:generates  sgo:Timeseries ]
    );
.
