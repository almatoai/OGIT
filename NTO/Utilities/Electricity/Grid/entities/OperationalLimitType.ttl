@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:OperationalLimitType
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "OperationalLimitType";
    dcterms:description "CIM cim:OperationalLimitType. Type-of-limit classifier (patl / tatl / dynamic / static + acceptable-duration window) shared by multiple OperationalLimit instances. CGMES-conformant typing of the limit semantics independent of the limit value.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:limitTypeKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:acceptableDurationSeconds
        ogit.Utilities.Electricity.Grid:directionKind
        ogit.Utilities.Electricity.Grid:isInfiniteDuration
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (

    );
.
