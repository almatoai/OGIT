@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:ProtectionEquipment
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "ProtectionEquipment";
    dcterms:description "CIM cim:ProtectionEquipment. Relay or protection device.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:protection_kind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:relay_delay_ms
        ogit.Utilities.Electricity.Grid:high_limit
        ogit.Utilities.Electricity.Grid:low_limit
        ogit.Utilities.Electricity.Grid:manufacturer
        ogit.Utilities.Electricity.Grid:model
        ogit.Utilities.Electricity.Grid:firmware_version
        ogit.Utilities:commissioning_year
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:protects  ogit.Utilities.Electricity.Grid:ACLineSegment ]
        [ ogit.Utilities.Electricity.Grid:operatesOn  ogit.Utilities.Electricity.Grid:Breaker ]
        [ ogit.Utilities.Electricity.Grid:generates  sgo:Timeseries ]
    );
.
