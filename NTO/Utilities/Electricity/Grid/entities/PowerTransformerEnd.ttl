@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:PowerTransformerEnd
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity.Grid:TransformerEnd;
    rdfs:label "PowerTransformerEnd";
    dcterms:description "CIM cim:PowerTransformerEnd. Typed end of a PowerTransformer; carries per-winding electrical parameters.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity.Grid:end_number
        ogit.Utilities.Electricity.Grid:rated_s_mva
        ogit.Utilities.Electricity.Grid:rated_u_kv
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:r_ohm
        ogit.Utilities.Electricity.Grid:x_ohm
        ogit.Utilities.Electricity.Grid:b_siemens
        ogit.Utilities.Electricity.Grid:g_siemens
        ogit.Utilities.Electricity.Grid:r0_ohm
        ogit.Utilities.Electricity.Grid:x0_ohm
        ogit.Utilities.Electricity.Grid:phase_angle_clock
        ogit.Utilities.Electricity.Grid:connection_kind
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Grid:partOf  ogit.Utilities.Electricity.Grid:PowerTransformer ]
    );
.
