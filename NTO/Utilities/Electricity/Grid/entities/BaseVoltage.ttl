@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Grid:BaseVoltage
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "BaseVoltage";
    dcterms:description "CIM cim:BaseVoltage. Reusable nominal-voltage reference shared by VoltageLevel, TransformerEnd, Terminal, ACLineSegment. Used so that the same nominal voltage value can be referenced by many objects without duplication of the numeric value.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity.Grid:nominalVoltageKv
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Grid:isDc
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity.Grid:VoltageLevel ]
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity.Grid:TransformerEnd ]
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity.Grid:Terminal ]
        [ ogit.Utilities:appliesTo  ogit.Utilities.Electricity.Grid:ACLineSegment ]
    );
.
