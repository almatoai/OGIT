ogit.Utilities.Electricity.Market:direction
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "direction";
    dcterms:description "Direction qualifier of a flowgate / capacity / settlement: a_to_b, b_to_a, both.";
