ogit.Utilities.Electricity.Market:marketKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "marketKind";
    dcterms:description "Market kind: day_ahead, intraday, balancing_capacity, balancing_energy, cross_zonal_capacity.";
    dcterms:valid "start=2026-05-28;";
