@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Electricity.Market:qualificationStatus
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "qualificationStatus";
    dcterms:description "Qualification status of the registered resource (lifecycle order): pending (in qualification process), pre_qualified (passed initial review), qualified (fully qualified), conditional (with conditions), suspended, revoked, expired (qualification has lapsed and needs renewal -- distinct from revoked).";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "pending,pre_qualified,qualified,conditional,suspended,revoked,expired";
.
