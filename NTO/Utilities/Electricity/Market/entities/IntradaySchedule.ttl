@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Market:IntradaySchedule
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities:Schedule;
    rdfs:label "IntradaySchedule";
    dcterms:description "Intraday-market scheduling. Granularity typically 15 min.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities:schedule_id
        ogit.Utilities:schedule_kind
        ogit.Utilities:valid_from
        ogit.Utilities:valid_until
        ogit.Utilities:granularity_seconds
    );
    ogit:optional-attributes (

    );
    ogit:indexed-attributes (
        ogit.Utilities:schedule_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Market:appliesTo  ogit.Utilities.Electricity:BiddingZone ]
        [ ogit.Utilities.Electricity.Market:generates  sgo:Timeseries ]
    );
.
