@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Market:AllocatedTransmissionCapacity
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "AllocatedTransmissionCapacity";
    dcterms:description "NC CACM Article 33 allocated cross-zonal capacity per market session. Records one allocation outcome with volume, price, and the winning participant.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Market:allocationId
        ogit.Utilities.Electricity.Market:fromZoneRef
        ogit.Utilities.Electricity.Market:toZoneRef
        ogit.Utilities:periodStart
        ogit.Utilities:periodEnd
        ogit.Utilities.Electricity.Market:allocatedVolumeMw
        ogit.Utilities.Electricity.Market:priceEurPerMw
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Market:participantRef
        ogit.Utilities.Electricity.Market:allocationMethod
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Market:allocationId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Market:awardedTo  ogit.Utilities.Electricity:MarketParticipant ]
        [ ogit.Utilities.Electricity:governedBy  ogit.Utilities.Electricity.Market:Market ]
    );
.
