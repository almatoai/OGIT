@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Market:Market
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "Market";
    dcterms:description "ENTSO-E market construct: SDAC, SIDC, TERRE, MARI, PICASSO. The vertex represents the market as a service operated by a market-coupling operator over one or more BiddingZones.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Market:market_id
        ogit:name
        ogit.Utilities.Electricity.Market:market_kind
        ogit.Utilities:operator_ref
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Market:coupling_method
        ogit.Utilities.Electricity.Market:gate_closure_time_zone
        ogit.Utilities.Electricity.Market:participants_count
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Market:market_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Market:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit.Utilities.Electricity.Market:covers  ogit.Utilities.Electricity:BiddingZone ]
        [ ogit.Utilities.Electricity.Market:trades  ogit.Utilities.Electricity.Market:EnergyProduct ]
    );
.
