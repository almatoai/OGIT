@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity.Grid:           <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Market:FlowGate
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "FlowGate";
    dcterms:description "NC CACM Article 7 critical network element flowgate used in flow-based capacity calculation.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Market:flowgate_id
        ogit:name
        ogit.Utilities.Electricity.Market:subject_branch_ref
        ogit.Utilities.Electricity.Market:direction
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Market:critical_outage_ref
        ogit.Utilities.Emissions:methodology
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Market:flowgate_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Market:appliesTo  ogit.Utilities.Electricity.Grid:ACLineSegment ]
        [ ogit.Utilities.Electricity.Market:appliesTo  ogit.Utilities.Electricity.Grid:DCLineSegment ]
        [ ogit.Utilities.Electricity.Market:partOf  ogit.Utilities.Electricity.Market:CrossZonalCapacity ]
    );
.
