@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Market:EnergyProduct
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "EnergyProduct";
    dcterms:description "ENTSO-E product catalogue entry. The standardised product traded in a market (EE-DA 1H, EE-ID 15min, Balancing-aFRR-Down-15min). The product_kind attribute carries the macro class.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Market:product_id
        ogit.Utilities.Electricity.Market:product_kind
        ogit.Utilities:granularity_seconds
        ogit.Utilities.Electricity.Market:delivery_unit
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Market:bidding_zone_ref
        ogit.Utilities.Electricity:currency_iso
        ogit.Utilities.Electricity.Market:min_volume_mwh
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Market:product_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Market:tradedAs  ogit.Utilities.Electricity.Market:Market ]
        [ ogit.Utilities.Electricity.Market:referencedBy  ogit.Utilities.Electricity.Market:AllocatedTransmissionCapacity ]
    );
.
