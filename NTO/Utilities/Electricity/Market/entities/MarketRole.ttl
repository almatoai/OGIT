@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Market:MarketRole
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "MarketRole";
    dcterms:description "ENTSO-E EIC market roles. A vertex per role kind so MarketParticipants can hold multiple authoritative roles simultaneously through heldBy edges. The role_kind attribute on MarketParticipant is a convenience flat copy; the authoritative role assignment is the MarketRole vertex.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Market:role_id
        ogit.Utilities.Electricity:role_kind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:description_text
        ogit.Utilities.Electricity.Market:regulatory_basis_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Market:role_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Market:heldBy  ogit.Utilities.Electricity:MarketParticipant ]
    );
.
