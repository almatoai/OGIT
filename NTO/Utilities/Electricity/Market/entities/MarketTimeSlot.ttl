@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity.Market:         <http://www.purl.org/ogit/Utilities/Electricity/Market/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity.Market:MarketTimeSlot
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "MarketTimeSlot";
    dcterms:description "Market period definition. One slot maps to a (period_start, period_end) interval at the product granularity.";
    dcterms:valid "start=2026-05-28;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity.Market:slot_id
        ogit.Utilities.Emissions:period_start
        ogit.Utilities.Emissions:period_end
        ogit.Utilities:granularity_seconds
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity.Market:bidding_zone_ref
        ogit.Utilities.Electricity.Market:product_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity.Market:slot_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity.Market:partOf  ogit.Utilities:Schedule ]
        [ ogit.Utilities.Electricity.Market:partOf  ogit.Utilities.Electricity.Market:Market ]
    );
.
