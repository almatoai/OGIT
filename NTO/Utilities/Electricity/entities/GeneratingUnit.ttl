@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:GeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "GeneratingUnit";
    dcterms:description "ABSTRACT: CIM cim:GeneratingUnit -- abstract parent of the typed generating units (Thermal, Nuclear, Hydro, Wind, Solar). Holds rated capacity, control parameters and the Kundur inertia constant. Time-variant state of the unit lives only on sgo:Timeseries vertices attached via generates.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:rated_p_mw
        ogit.Utilities.Electricity:min_operating_p_mw
        ogit.Utilities.Electricity:max_operating_p_mw
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:nominal_p_mw
        ogit.Utilities.Electricity:rated_voltage_kv
        ogit.Utilities.Electricity:inertia_constant_h_s
        ogit.Utilities.Electricity:governor_p_mw_per_hz
        ogit.Utilities.Electricity:control_response_kind
        ogit.Utilities:commissioning_year
        ogit.Utilities.Electricity:decommissioning_year
        ogit.Utilities.Electricity:lifecycle_status_snapshot
        ogit.Utilities.Electricity:fuel_efficiency
        ogit.Utilities.Electricity:min_run_time_h
        ogit.Utilities.Electricity:min_down_time_h
        ogit.Utilities.Electricity:startup_cost
        ogit.Utilities.Electricity:variable_cost_per_mwh
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity:partOf  ogit.Utilities.Electricity:PowerPlant ]
        [ ogit.Utilities.Electricity:controlledBy  ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities.Electricity:emits  ogit.Utilities.Emissions:GreenhouseGasEmission ]
        [ ogit.Utilities.Electricity:consumes  ogit.Utilities:EnergyCarrier ]
        [ ogit.Utilities.Electricity:generates  sgo:Timeseries ]
    );
.
