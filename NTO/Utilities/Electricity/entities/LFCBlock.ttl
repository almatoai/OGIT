@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:LFCBlock
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "LFCBlock";
    dcterms:description "ENTSO-E NC SO Article 141 LFC Block. Grouping of LFC Areas for AGC purposes. Continental Europe defines multiple LFC Blocks; holds the block-responsible party reference and the dimensioning incident MW used for reserve sizing.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:blockName
        ogit.Utilities.Electricity:blockEic
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:parentSynchronousAreaRef
        ogit.Utilities.Electricity:memberLfcAreaRefs
        ogit.Utilities.Electricity:blockResponsiblePartyRef
        ogit.Utilities.Electricity:dimensioningIncidentMw
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:blockEic
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity:SynchronousArea ]
        [ ogit:consistsOf  ogit.Utilities.Electricity:LFCArea ]
    );
.
