@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:LFCBlock
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "LFCBlock";
    dcterms:description "ENTSO-E NC SO Article 141 LFC Block. Grouping of LFC Areas for AGC purposes. Continental Europe defines multiple LFC Blocks; holds the block-responsible party reference and the dimensioning incident MW used for reserve sizing.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:block_name
        ogit.Utilities.Electricity:block_eic
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:parent_synchronous_area_ref
        ogit.Utilities.Electricity:member_lfc_area_refs
        ogit.Utilities.Electricity:block_responsible_party_ref
        ogit.Utilities.Electricity:dimensioning_incident_mw
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:block_eic
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity:partOf  ogit.Utilities.Electricity:SynchronousArea ]
        [ ogit.Utilities.Electricity:consistsOf  ogit.Utilities.Electricity:LFCArea ]
    );
.
