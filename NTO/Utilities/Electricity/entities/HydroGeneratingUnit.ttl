@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:HydroGeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:GeneratingUnit;
    rdfs:label "HydroGeneratingUnit";
    dcterms:description "CIM cim:HydroGeneratingUnit. Run-of-river, reservoir, pumped-storage, tidal. Adds head, reservoir capacity, dam parameters, and cascade-position references. Pumped-storage is modelled here whenever turbine parameters matter; the bare-storage view of pumped hydro is captured by a separate EnergyStorage vertex on the same physical asset.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:ratedPMw
        ogit.Utilities.Electricity:minOperatingPMw
        ogit.Utilities.Electricity:maxOperatingPMw
        ogit.Utilities.Electricity:hydroKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:headMeters
        ogit.Utilities.Electricity:reservoirCapacityMcm
        ogit.Utilities.Electricity:damHeightM
        ogit.Utilities.Electricity:riverName
        ogit.Utilities.Electricity:installedYear
        ogit.Utilities.Electricity:pumpCapacityMw
        ogit.Utilities.Electricity:roundTripEfficiency
        ogit.Utilities.Electricity:minStorageMwh
        ogit.Utilities.Electricity:maxStorageMwh
        ogit.Utilities.Electricity:cascadePosition
        ogit.Utilities.Electricity:upstreamUnitRef
        ogit.Utilities.Electricity:downstreamUnitRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (

    );
.
