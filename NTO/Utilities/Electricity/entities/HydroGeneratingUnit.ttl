@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:HydroGeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:GeneratingUnit;
    rdfs:label "HydroGeneratingUnit";
    dcterms:description "CIM cim:HydroGeneratingUnit. Run-of-river, reservoir, pumped-storage, tidal. Adds head, reservoir capacity, dam parameters, and cascade-position references. Pumped-storage is modelled here whenever turbine parameters matter; the bare-storage view of pumped hydro is captured by a separate EnergyStorage vertex on the same physical asset.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:rated_p_mw
        ogit.Utilities.Electricity:min_operating_p_mw
        ogit.Utilities.Electricity:max_operating_p_mw
        ogit.Utilities.Electricity:hydro_kind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:head_meters
        ogit.Utilities.Electricity:reservoir_capacity_mcm
        ogit.Utilities.Electricity:dam_height_m
        ogit.Utilities.Electricity:river_name
        ogit.Utilities.Electricity:installed_year
        ogit.Utilities.Electricity:pump_capacity_mw
        ogit.Utilities.Electricity:round_trip_efficiency
        ogit.Utilities.Electricity:min_storage_mwh
        ogit.Utilities.Electricity:max_storage_mwh
        ogit.Utilities.Electricity:cascade_position
        ogit.Utilities.Electricity:upstream_unit_ref
        ogit.Utilities.Electricity:downstream_unit_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (

    );
.
