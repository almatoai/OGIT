@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:PowerPlant
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "PowerPlant";
    dcterms:description "Pragmatic aggregate above GeneratingUnit. Not a first-class CIM class but ubiquitous in asset-register and plant-inventory sources, which aggregate at plant level rather than at the unit level CIM defines. Holds plant identity, the plant operator, the primary energy carrier and the aggregate capacity rollups.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:plant_name
        ogit.Utilities.Electricity:plant_id
    );
    ogit:optional-attributes (
        ogit.Utilities:operator_ref
        ogit.Utilities:country_iso2
        ogit.Utilities:location_ref
        ogit.Utilities.Electricity:total_rated_p_mw
        ogit.Utilities.Electricity:total_storage_mwh
        ogit.Utilities.Electricity:primary_carrier_ref
        ogit.Utilities:commissioning_year
        ogit.Utilities.Electricity:decommissioning_year
        ogit.Utilities.Electricity:replaces_plant_ref
        ogit:status
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:plant_id
        ogit.Utilities.Electricity:plant_name
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity:consistsOf  ogit.Utilities.Electricity:GeneratingUnit ]
        [ ogit.Utilities.Electricity:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit.Utilities.Electricity:emits  ogit.Utilities.Emissions:GreenhouseGasEmission ]
    );
.
