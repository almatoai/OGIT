@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:EnergyStorage
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:PowerSystemResource;
    rdfs:label "EnergyStorage";
    dcterms:description "CIM cim:EnergyStorage. Lithium-ion batteries (BESS), flow batteries, pumped hydro (when modelled as black-box storage), compressed air, flywheel, thermal, hydrogen, gravity. State of charge is time-variant and lives only on a sgo:Timeseries via generates -- not as a vertex attribute.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:storageKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:ratedPMw
        ogit.Utilities.Electricity:ratedEMwh
        ogit.Utilities.Electricity:roundTripEfficiency
        ogit.Utilities.Electricity:minSocPercent
        ogit.Utilities.Electricity:maxSocPercent
        ogit.Utilities.Electricity:cycleCount
        ogit.Utilities.Electricity:calendarLifeYears
        ogit.Utilities.Electricity:cRate
        ogit.Utilities.Electricity:connectionVoltageKv
        ogit.Utilities:commissioningYear
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity:aliasName
        ogit.Utilities.Electricity:categoryRef
        ogit.Utilities:commissioningDate
        ogit.Utilities:decommissioningDate
        ogit.Utilities.Electricity:psrType
        ogit.Utilities.Electricity:externalRefs
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:allowed (
        [ ogit:generates  sgo:Timeseries ]
        [ ogit.Utilities.Electricity:storesEnergy  ogit.Utilities:EnergyCarrier ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:locatedIn  ogit:Location ]
    );
.
