@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:LFCArea
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "LFCArea";
    dcterms:description "CIM cim:LfcArea. Load-frequency-control area. Finer than SynchronousArea, coarser-than-or-equal to ControlArea. Used in the ENTSO-E NC SO Article 141 grouping for AGC purposes.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:areaName
        ogit.Utilities.Electricity:areaEic
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:parentSynchronousAreaRef
        ogit.Utilities.Electricity:memberControlAreaRefs
        ogit.Utilities.Electricity:aceOpenLoopGain
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:areaEic
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity:SynchronousArea ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:LFCBlock ]
        [ ogit:consistsOf  ogit.Utilities.Electricity:ControlArea ]
    );
.
