@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:EnergyConsumer
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "EnergyConsumer";
    dcterms:description "CIM cim:EnergyConsumer -- generic load class. Industrial, commercial, residential, traction, electrolysis, pumped-storage charge. Time-variant load lives on a sgo:Timeseries attached via generates.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:nominalPMw
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:nominalQMvar
        ogit.Utilities.Electricity:consumerKind
        ogit.Utilities.Electricity:dispatchable
        ogit.Utilities.Electricity:interruptible
        ogit.Utilities.Electricity:loadProfileRef
        ogit.Utilities.Electricity:connectionVoltageKv
        ogit.Utilities.Electricity:customerCount
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity:aliasName
        ogit.Utilities.Electricity:categoryRef
        ogit.Utilities:commissioningDate
        ogit.Utilities:decommissioningDate
        ogit.Utilities.Electricity:psrType
        ogit.Utilities.Electricity:externalRefs
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:allowed (
        [ ogit:consumes  ogit.Utilities:EnergyCarrier ]
        [ ogit.Utilities.Electricity:subscribesTo  ogit.Utilities:Schedule ]
        [ ogit:generates  ogit:Timeseries ]
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
    );
.
