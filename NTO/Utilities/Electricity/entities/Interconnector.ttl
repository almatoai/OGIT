@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:Interconnector
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "Interconnector";
    dcterms:description "Cross-border physical connection between two ControlAreas. Either AC (multiple parallel ACLineSegments) or HVDC (one bipole). **Business-level aggregate** above the equipment hierarchy -- distinct from `Utilities.Electricity.Grid:EquipmentContainer` (which is the CIM physical-containment hierarchy: Substation / VoltageLevel / Bay). Concrete ACLineSegment / Line / DCLineSegment instances both connect at the equipment level (hasTerminal -> Terminal) AND aggregate up to one Interconnector via `ogit:isPartOf` to express the business-level cross-border link. Shared ownership and operation are modelled via reified OwnershipShare on the Interconnector vertex (concept Section 8.1).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:interconnectorName
        ogit.Utilities.Electricity:interconnectorId
        ogit.Utilities.Electricity:endpointAControlAreaRef
        ogit.Utilities.Electricity:endpointBControlAreaRef
        ogit.Utilities.Electricity:technology
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:ratedPMw
        ogit.Utilities.Electricity:lengthKm
        ogit.Utilities:commissioningYear
        ogit.Utilities.Electricity:decommissioningYear
        ogit.Utilities.Electricity:routingCountryIso2List
        ogit.Utilities.Electricity:submarine
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:interconnectorId
    );
    ogit:allowed (
        [ ogit:connects  ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities.Electricity:transports  ogit.Utilities:EnergyCarrier ]
    );
.
