@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:WindGeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:GeneratingUnit;
    rdfs:label "WindGeneratingUnit";
    dcterms:description "CIM cim:WindGeneratingUnit. Onshore, offshore-fixed, offshore-floating. Adds turbine count, rotor and hub geometry, cut-in / cut-out / rated wind speeds, and offshore-specific parameters (water body, depth, foundation type, connection technology).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:ratedPMw
        ogit.Utilities.Electricity:minOperatingPMw
        ogit.Utilities.Electricity:maxOperatingPMw
        ogit.Utilities.Electricity:windKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:turbineCount
        ogit.Utilities.Electricity:turbineModel
        ogit.Utilities.Electricity:rotorDiameterM
        ogit.Utilities.Electricity:hubHeightM
        ogit.Utilities.Electricity:cutInSpeedMs
        ogit.Utilities.Electricity:cutOutSpeedMs
        ogit.Utilities.Electricity:ratedSpeedMs
        ogit.Utilities.Electricity:waterBody
        ogit.Utilities.Electricity:waterDepthM
        ogit.Utilities.Electricity:foundationType
        ogit.Utilities.Electricity:connectionType
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (

    );
.
