@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:PowerSystemResource
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "PowerSystemResource";
    dcterms:description "ABSTRACT: CIM cim:PowerSystemResource -- the root of every CIM electrical resource. Most concrete classes in this sub-namespace and the Grid sub-namespace derive from it. Holds the cross-resource attributes mrid, name, commissioning dates, operator reference, and the verbs locatedIn / operatedBy / ownedBy / partOf.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity:aliasName
        ogit.Utilities.Electricity:categoryRef
        ogit.Utilities:operatorRef
        ogit.Utilities.Electricity:commissioningDate
        ogit.Utilities.Electricity:decommissioningDate
        ogit.Utilities.Electricity:psrType
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:allowed (
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
    );
.
