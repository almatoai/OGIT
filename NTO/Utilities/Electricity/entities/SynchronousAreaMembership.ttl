@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:SynchronousAreaMembership
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "SynchronousAreaMembership";
    dcterms:description "Reified membership of a ControlArea or BiddingZone in a SynchronousArea over a validity window. Empirical anchor: Baltic states leaving IPS/UPS on 2025-02-09 to join Continental Europe. Concept Section 8.3.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:membershipId
        ogit:validFrom
    );
    ogit:optional-attributes (
        ogit.Utilities:validUntil
        ogit.Utilities.Electricity:transitionReason
        ogit.Utilities.Electricity:desynchronisationEventRef
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:membershipId
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity:memberOf  ogit.Utilities.Electricity:SynchronousArea ]
        [ ogit.Utilities.Electricity:memberSubject  ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities.Electricity:memberSubject  ogit.Utilities.Electricity:BiddingZone ]
    );
.
