@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:SolarGeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:GeneratingUnit;
    rdfs:label "SolarGeneratingUnit";
    dcterms:description "CIM cim:SolarGeneratingUnit. PV (rooftop, ground-mount, floating, agri-PV) and CSP. Adds panel technology, tracking kind, geometric orientation, DC-to-AC ratio, inverter and panel counts, plus CSP-specific storage parameters.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:ratedPMw
        ogit.Utilities.Electricity:minOperatingPMw
        ogit.Utilities.Electricity:maxOperatingPMw
        ogit.Utilities.Electricity:pvKind
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:panelTechnology
        ogit.Utilities.Electricity:trackingKind
        ogit.Utilities.Electricity:tiltAngleDeg
        ogit.Utilities.Electricity:azimuthDeg
        ogit.Utilities.Electricity:dcToAcRatio
        ogit.Utilities.Electricity:inverterCount
        ogit.Utilities.Electricity:panelCount
        ogit.Utilities.Electricity:cspTechnology
        ogit.Utilities.Electricity:cspStorageH
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (

    );
.
