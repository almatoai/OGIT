@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:NuclearGeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:GeneratingUnit;
    rdfs:label "NuclearGeneratingUnit";
    dcterms:description "CIM cim:NuclearGeneratingUnit. PWR, BWR, EPR, WWER-440/1000, AGR, CANDU, RBMK. Adds reactor type, count, fuel-cycle class, cooling system, and the IAEA registry identifier.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:rated_p_mw
        ogit.Utilities.Electricity:min_operating_p_mw
        ogit.Utilities.Electricity:max_operating_p_mw
        ogit.Utilities.Electricity:reactor_type
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:reactor_count
        ogit.Utilities.Electricity:reactor_supplier
        ogit.Utilities.Electricity:fuel_cycle_class
        ogit.Utilities.Electricity:cooling_system
        ogit.Utilities.Electricity:cooling_water_source
        ogit.Utilities.Electricity:regulatory_status
        ogit.Utilities.Electricity:licensee_ref
        ogit.Utilities.Electricity:iaea_registry_id
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity:iaea_registry_id
    );
    ogit:allowed (

    );
.
