@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:NuclearGeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:GeneratingUnit;
    rdfs:label "NuclearGeneratingUnit";
    dcterms:description "CIM cim:NuclearGeneratingUnit. PWR, BWR, EPR, WWER-440/1000, AGR, CANDU, RBMK. Adds reactor type, count, fuel-cycle class, cooling system, and the IAEA registry identifier.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:ratedPMw
        ogit.Utilities.Electricity:minOperatingPMw
        ogit.Utilities.Electricity:maxOperatingPMw
        ogit.Utilities.Electricity:reactorType
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:reactorCount
        ogit.Utilities.Electricity:reactorSupplier
        ogit.Utilities.Electricity:fuelCycleClass
        ogit.Utilities.Electricity:coolingSystem
        ogit.Utilities.Electricity:coolingWaterSource
        ogit.Utilities.Electricity:regulatoryStatus
        ogit.Utilities.Electricity:licenseeRef
        ogit.Utilities.Electricity:iaeaRegistryId
        ogit.Utilities.Electricity:nominalPMw
        ogit.Utilities.Electricity:ratedVoltageKv
        ogit.Utilities.Electricity:inertiaConstantHS
        ogit.Utilities.Electricity:governorPMwPerHz
        ogit.Utilities.Electricity:controlResponseKind
        ogit.Utilities.Electricity:rfgConnectionType
        ogit.Utilities:commissioningYear
        ogit.Utilities.Electricity:decommissioningYear
        ogit.Utilities.Electricity:lifecycleStatusSnapshot
        ogit.Utilities.Electricity:fuelEfficiency
        ogit.Utilities.Electricity:minRunTimeH
        ogit.Utilities.Electricity:minDownTimeH
        ogit.Utilities.Electricity:startupCost
        ogit.Utilities.Electricity:variableCostPerMwh
        ogit.Utilities.Electricity:descriptionText
        ogit.Utilities.Electricity:aliasName
        ogit.Utilities.Electricity:categoryRef
        ogit.Utilities:commissioningDate
        ogit.Utilities:decommissioningDate
        ogit.Utilities.Electricity:psrType
        ogit.Utilities.Electricity:externalRefs
        ogit:status
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit.Utilities.Electricity:iaeaRegistryId
        ogit:name
    );
    ogit:allowed (
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
        [ ogit:controlledBy  ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities:emits  ogit.Utilities.Emissions:GreenhouseGasEmission ]
        [ ogit:consumes  ogit.Utilities:EnergyCarrier ]
        [ ogit:generates  sgo:Timeseries ]
        [ ogit.Utilities:operatedBy  ogit.Utilities:NetworkOperator ]
        [ ogit:locatedIn  ogit:Location ]
        [ ogit:isPartOf  ogit.Utilities.Electricity:PowerPlant ]
    );
.
