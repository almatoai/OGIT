@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:TieFlow
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "TieFlow";
    dcterms:description "CIM cim:TieFlow. The signed-flow contribution of one Terminal toward one ControlArea net-interchange computation. Captures the convention 'does positive measurement direction count as inflow to this control area'.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:tieflow_id
        ogit.Utilities.Electricity:terminal_ref
        ogit.Utilities.Electricity:control_area_ref
        ogit.Utilities.Electricity:positive_flow_in
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:interconnector_ref
        ogit.Utilities.Electricity:measurement_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:tieflow_id
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity:partOf  ogit.Utilities.Electricity:ControlArea ]
    );
.
