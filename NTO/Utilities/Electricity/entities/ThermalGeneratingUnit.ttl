@prefix ogit:                              <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                    <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Electricity:        <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Electricity.Grid:   <http://www.purl.org/ogit/Utilities/Electricity/Grid/> .
@prefix ogit.Utilities.Electricity.Telecontrol: <http://www.purl.org/ogit/Utilities/Electricity/Telecontrol/> .
@prefix ogit.Utilities.Emissions:          <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix sgo:                               <http://www.purl.org/ogit/SGO/sgo/> .
@prefix owl:                               <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                              <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                           <http://purl.org/dc/terms/> .

ogit.Utilities.Electricity:ThermalGeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:GeneratingUnit;
    rdfs:label "ThermalGeneratingUnit";
    dcterms:description "Thermal generating unit subtype of GeneratingUnit. Covers coal, lignite, gas (CCGT, OCGT), oil, biomass, geothermal, oil-shale. CIM cim:ThermalGeneratingUnit. Per concept Section 5.1 attribute inheritance from GeneratingUnit and PowerSystemResource is materialised here -- the mandatory and optional lists carry the full set, parent attributes plus the subtype-specific fuel_type and cycle parameters.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:rated_p_mw
        ogit.Utilities.Electricity:min_operating_p_mw
        ogit.Utilities.Electricity:max_operating_p_mw
        ogit.Utilities.Electricity:fuel_type
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:nominal_p_mw
        ogit.Utilities.Electricity:rated_voltage_kv
        ogit.Utilities.Electricity:inertia_constant_h_s
        ogit.Utilities.Electricity:governor_p_mw_per_hz
        ogit.Utilities.Electricity:control_response_kind
        ogit.Utilities.Electricity:thermal_efficiency
        ogit.Utilities.Electricity:cycle_kind
        ogit.Utilities.Electricity:chp_capable
        ogit.Utilities.Electricity:cogeneration_thermal_capacity_mw
        ogit.Utilities.Electricity:boiler_count
        ogit.Utilities.Electricity:turbine_count
        ogit.Utilities.Electricity:min_ramp_up_rate_mw_min
        ogit.Utilities.Electricity:min_ramp_down_rate_mw_min
        ogit.Utilities.Electricity:cold_start_time_min
        ogit.Utilities.Electricity:warm_start_time_min
        ogit.Utilities.Electricity:hot_start_time_min
        ogit.Utilities.Electricity:commissioning_year
        ogit.Utilities.Electricity:decommissioning_year
        ogit.Utilities.Electricity:lifecycle_status_snapshot
        ogit:source
        ogit:sourceId
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
    );
    ogit:allowed (
        [ ogit:partOf                                          ogit.Utilities.Electricity:PowerPlant ]
        [ ogit:partOf                                          ogit.Utilities.Electricity.Grid:Substation ]
        [ ogit.Utilities.Electricity:controlledBy              ogit.Utilities.Electricity:ControlArea ]
        [ ogit.Utilities.Electricity:operatedBy                ogit.Utilities:NetworkOperator ]
        [ ogit.Utilities.Emissions:emits                       ogit.Utilities.Emissions:GreenhouseGasEmission ]
        [ ogit.Utilities.Electricity:consumes                  ogit.Utilities:EnergyCarrier ]
        [ ogit.Utilities.Electricity.Grid:measuredBy           ogit.Utilities.Electricity.Telecontrol:DataPoint ]
        [ ogit:generates                                       sgo:Timeseries ]
    );
.
