@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Electricity:                <http://www.purl.org/ogit/Utilities/Electricity/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Electricity:ThermalGeneratingUnit
    a rdfs:Class;
    rdfs:subClassOf ogit.Utilities.Electricity:GeneratingUnit;
    rdfs:label "ThermalGeneratingUnit";
    dcterms:description "CIM cim:ThermalGeneratingUnit. Coal, lignite, gas (CCGT / OCGT), oil, biomass, geothermal, oil-shale. Adds fuel and thermodynamic-cycle parameters plus start-time and ramp-rate characteristics.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Electricity:mrid
        ogit:name
        ogit.Utilities.Electricity:rated_p_mw
        ogit.Utilities.Electricity:min_operating_p_mw
        ogit.Utilities.Electricity:max_operating_p_mw
        ogit.Utilities.Electricity:fuel_type
    );
    ogit:optional-attributes (
        ogit.Utilities.Electricity:thermal_efficiency
        ogit.Utilities.Electricity:cycle_kind
        ogit.Utilities.Electricity:chp_capable
        ogit.Utilities.Electricity:boiler_count
        ogit.Utilities.Electricity:turbine_count
        ogit.Utilities.Electricity:cogeneration_thermal_capacity_mw
        ogit.Utilities.Electricity:min_ramp_up_rate_mw_min
        ogit.Utilities.Electricity:min_ramp_down_rate_mw_min
        ogit.Utilities.Electricity:cold_start_time_min
        ogit.Utilities.Electricity:warm_start_time_min
        ogit.Utilities.Electricity:hot_start_time_min
    );
    ogit:indexed-attributes (
        ogit.Utilities.Electricity:mrid
    );
    ogit:allowed (
        [ ogit.Utilities.Electricity:partOf  ogit.Utilities.Electricity:PowerPlant ]
        [ ogit.Utilities.Electricity:emits  ogit.Utilities.Emissions:GreenhouseGasEmission ]
        [ ogit.Utilities.Electricity:generates  sgo:Timeseries ]
    );
.
