@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities:limitKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "limitKind";
    dcterms:description "Domain-specific limit classification: for electricity (PATL, TATL, voltage_high, voltage_low, current_high, current_low, frequency_high, frequency_low, apparent_power, active_power, reactive_power); for gas (pressure_high, pressure_low, flow_high, flow_low); for water (level_high, level_low, flow_high, flow_low). Other utility domains add their own kinds; the list is intentionally open. etc.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
