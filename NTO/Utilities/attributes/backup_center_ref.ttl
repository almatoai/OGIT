ogit.Utilities:backup_center_ref
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "backup_center_ref";
    dcterms:description "Reference to the ControlCenter vertex that takes over operations on failure of the primary.";
