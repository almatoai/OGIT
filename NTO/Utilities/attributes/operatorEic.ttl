@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities:operatorEic
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "operatorEic";
    dcterms:description "ENTSO-E EIC identifier for the operator (X-code for transmission operators, Y-code for market participants). 16-character format with check digit per ENTSO-E EIC specification.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
