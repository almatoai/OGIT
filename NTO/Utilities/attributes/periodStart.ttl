@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities:periodStart
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "periodStart";
    dcterms:description "Reporting / accounting / settlement period start timestamp (ISO 8601, UTC). Used by GreenhouseGasEmission and EmissionInventory (Emissions namespace), Allocation and Settlement (Market namespace), BalancingEnergyBid / BalancingCapacityBid / Activation / Settlement (Reserves namespace). Lives in Utilities as the lowest common ancestor.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
