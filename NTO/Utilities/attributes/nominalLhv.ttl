ogit.Utilities:nominalLhv
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "nominalLhv";
    dcterms:description "Lower heating value at standard temperature and pressure, in J/kg for solids/liquids or J/m3 for gases.";
