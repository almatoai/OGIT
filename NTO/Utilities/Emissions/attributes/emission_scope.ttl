@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Emissions:emission_scope
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "emission_scope";
    dcterms:description "Emissions scope classification per GHG Protocol: Scope 1 (direct), Scope 2 (electricity), Scope 3 (indirect).";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
.
