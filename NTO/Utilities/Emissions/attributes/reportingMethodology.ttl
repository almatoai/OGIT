@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Emissions:reportingMethodology
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "reportingMethodology";
    dcterms:description "Reporting methodology: IPCC 2006 Tier 1 / Tier 2 / Tier 3, GHG Protocol, EU ETS, regional inventory.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
.
