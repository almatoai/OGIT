@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Emissions:substance
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "substance";
    dcterms:description "Measured substance scope: Kyoto-Protocol greenhouse gases (CO2, CH4, N2O, SF6, NF3, HFC, PFC) plus core EEA NEC air-quality pollutants (NOx, SO2, NMVOC, NH3, particulate_matter, PM2_5, mercury) and selected heavy metals (arsenic, cadmium, chromium, nickel, lead), the aggregate POP-marker dioxins_furans, plus the aggregate CO2_equivalent. The full E-PRTR pollutant register (~91 substances) is intentionally out of scope; additional substances ride on a follow-up extension attribute when needed.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "CO2,CH4,N2O,SF6,NF3,HFC,PFC,NOx,SO2,NMVOC,NH3,particulate_matter,PM2_5,mercury,arsenic,cadmium,chromium,nickel,lead,dioxins_furans,CO2_equivalent";
.
