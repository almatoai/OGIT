@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .

ogit.Utilities.Emissions:obligationKind
    a owl:DatatypeProperty;
    rdfs:subPropertyOf ogit:Attribute;
    rdfs:label "obligationKind";
    dcterms:description "Reporting obligation classification: EU_ETS, UNFCCC, national_law (e.g. DE BEHG, UK-ETS, country-specific carbon-pricing regimes), voluntary, internal.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "Almato AG";
    ogit:validation-type "fixed";
    ogit:validation-parameter "EU_ETS,UNFCCC,national_law,voluntary,internal";
.
