ogit.Utilities.Emissions:submittedTo
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "submittedTo";
    dcterms:description "Asserts that an EmissionInventory is submitted to the target regulatory authority. Cardinality: many2one.";
