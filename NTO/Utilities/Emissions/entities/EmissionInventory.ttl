@prefix dcterms:                                   <http://purl.org/dc/terms/> .
@prefix ogit:                                      <http://www.purl.org/ogit/> .
@prefix ogit.Utilities:                            <http://www.purl.org/ogit/Utilities/> .
@prefix ogit.Utilities.Emissions:                  <http://www.purl.org/ogit/Utilities/Emissions/> .
@prefix owl:                                       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                                      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sgo:                                       <http://www.purl.org/ogit/SGO/sgo/> .


ogit.Utilities.Emissions:EmissionInventory
    a rdfs:Class;
    rdfs:subClassOf ogit:Entity;
    rdfs:label "EmissionInventory";
    dcterms:description "Accounting envelope for one reporting period, jurisdiction, and obligation (e.g. EU ETS yearly, national UNFCCC inventory). Aggregates from GreenhouseGasEmission records and ultimately submits to a regulatory authority.";
    dcterms:valid "start=2026-05-27;";
    dcterms:creator "chris.boos@almato.com";
    ogit:scope "NTO";
    ogit:parent ogit:Node;
    ogit:mandatory-attributes (
        ogit.Utilities.Emissions:inventory_id
        ogit.Utilities.Emissions:period_start
        ogit.Utilities.Emissions:period_end
        ogit.Utilities.Emissions:jurisdiction_ref
        ogit.Utilities.Emissions:obligation_kind
    );
    ogit:optional-attributes (
        ogit.Utilities.Emissions:submission_status
        ogit.Utilities.Emissions:total_quantity_kg_co2eq
        ogit.Utilities.Emissions:breakdown_payload
        ogit.Utilities.Emissions:auditor_ref
    );
    ogit:indexed-attributes (
        ogit.Utilities.Emissions:inventory_id
    );
    ogit:allowed (
        [ ogit.Utilities.Emissions:aggregatesFrom  ogit.Utilities.Emissions:GreenhouseGasEmission ]
        [ ogit.Utilities.Emissions:submittedTo  ogit.Utilities:NetworkOperator ]
    );
.
