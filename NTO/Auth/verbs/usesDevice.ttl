@prefix ogit:           <http://www.purl.org/ogit/> .
@prefix ogit.Auth:      <http://www.purl.org/ogit/Auth/> .
@prefix owl:            <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:           <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:        <http://purl.org/dc/terms/> .

ogit.Auth:usesDevice
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "usesDevice";
    dcterms:description "Connects an ogit.Auth:Account to an ogit.Auth:Device. Many-to-many: one Account may use several devices; one device may be used by several Accounts (e.g. a family tablet).";
    dcterms:valid "start=2026-06-01;";
    dcterms:creator "Almato AG";
    dcterms:created "2026-06-01";
    dcterms:modified "2026-06-01";
    ogit:admin-contact "Almato AG";
    ogit:tech-contact "Almato AG";
    ogit:history (
    );
.
