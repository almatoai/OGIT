@prefix ogit:    <http://www.purl.org/ogit/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ogit:administratorInInsolvencyOf
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "administratorInInsolvencyOf";
    dcterms:description "Indicates that the subject Person or Organization is the administrator in insolvency proceedings for the object Organization (UK administration, Chapter 11 trustee analogue). Distinct from administratorOf, which is the estate-probate role.";
    dcterms:valid "start=2026-05-02;";
    dcterms:creator "chris.boos@almato.com";
.
