@prefix ogit:    <http://www.purl.org/ogit/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ogit:wasBestManFor
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "wasBestManFor";
    dcterms:description "Indicates that the subject Person served as best man at the wedding of which the object Person (the groom) is the relevant spouse. In many common-law jurisdictions the best man is also a legal marriage witness.";
    dcterms:valid "start=2026-05-02;";
    dcterms:creator "chris.boos@almato.com";
.
