@prefix ogit:    <http://www.purl.org/ogit/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ogit:bornIn
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "bornIn";
    dcterms:description "Indicates that the subject Person was born in the object Region. Distinct from hasNationality because birth country and nationality often differ; distinct from the more generic ogit:originatesIn because compliance use cases need the specific birth-country claim, not generic origin.";
    dcterms:valid "start=2026-05-02;";
    dcterms:creator "chris.boos@almato.com";
.
