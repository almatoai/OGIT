@prefix ogit:    <http://www.purl.org/ogit/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ogit:settlorOf
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "settlorOf";
    dcterms:description "Indicates that the subject Person or Organization created the object Organization (a trust modelled as ogit:Organization with function='trust') by transferring assets in. Often the original beneficial owner; key for AML beneficial-ownership tracing.";
    dcterms:valid "start=2026-05-02;";
    dcterms:creator "chris.boos@almato.com";
.
