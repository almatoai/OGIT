@prefix ogit:    <http://www.purl.org/ogit/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ogit:partneredWith
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "partneredWith";
    dcterms:description "Indicates that the subject Organization is in a registered partnership (LLP, GP, LP) with the object Organization. Distinct from affiliateOf because partnership has specific liability and tax-treatment implications.";
    dcterms:valid "start=2026-05-02;";
    dcterms:creator "chris.boos@almato.com";
.
