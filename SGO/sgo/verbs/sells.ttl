@prefix ogit:                   <http://www.purl.org/ogit/> .
@prefix owl:                    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:                   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:                <http://purl.org/dc/terms/> .

ogit:sells
	a owl:ObjectProperty;
	rdfs:subPropertyOf ogit:Verb;
	rdfs:label "sells";
	dcterms:description "This relationship defines that one entity sells another entity.";
	# For ranges, see https://www.dublincore.org/specifications/dublin-core/dcmi-period/
	dcterms:valid "start=2019-11-06;";
	dcterms:creator "Marek Meyer";
