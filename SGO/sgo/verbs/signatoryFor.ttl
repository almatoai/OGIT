@prefix ogit:    <http://www.purl.org/ogit/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ogit:signatoryFor
    a owl:ObjectProperty;
    rdfs:subPropertyOf ogit:Verb;
    rdfs:label "signatoryFor";
    dcterms:description "Indicates that the subject Person has authorised signing power on accounts or contracts of the object Organization. Key for AML and sanctions enforcement -- signatories on a sanctioned entity's accounts trigger separate exposure.";
    dcterms:valid "start=2026-05-02;";
    dcterms:creator "chris.boos@almato.com";
.
